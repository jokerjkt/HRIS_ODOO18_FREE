<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="l10n_id_hr_payroll.SelfieCheckIn">
        <div class="o_selfie_checkin p-3">

            <!-- ── Header ─────────────────────────────────────────── -->
            <div class="text-center mb-4">
                <h3 class="fw-bold">
                    <i class="fa fa-camera"/> Absensi Mobile
                </h3>
                <p class="text-muted mb-0">Selfie + GPS untuk check-in/check-out</p>
            </div>

            <!-- ── GPS Status ─────────────────────────────────────── -->
            <div class="card mb-3" t-if="state.gpsReady">
                <div class="card-body py-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-success">GPS Aktif</span>
                        <small class="text-muted">
                            Lat: <t t-esc="state.latitude?.toFixed(6)"/>
                            | Lng: <t t-esc="state.longitude?.toFixed(6)"/>
                            | Akurasi: <t t-esc="state.accuracy?.toFixed(1)"/>m
                        </small>
                    </div>
                </div>
            </div>

            <div class="alert alert-warning py-2" t-if="state.gpsError">
                <i class="fa fa-exclamation-triangle"/>
                <t t-esc="state.gpsError"/>
            </div>

            <!-- ── Mode: Idle (Start) ─────────────────────────────── -->
            <div t-if="state.mode === 'idle'" class="text-center py-5">
                <div class="mb-4">
                    <i class="fa fa-camera fa-4x text-muted" style="opacity: 0.3"/>
                </div>
                <p class="text-muted mb-4">
                    Tekan tombol di bawah untuk mulai absensi dengan selfie
                </p>
                <button class="btn btn-primary btn-lg px-5 py-3"
                        t-on-click="onStartCamera"
                        t-att-disabled="!state.gpsReady">
                    <i class="fa fa-camera me-2"/>
                    Mulai Selfie
                </button>
                <p class="text-muted mt-2" t-if="!state.gpsReady">
                    <small>Menunggu GPS siap...</small>
                </p>
            </div>

            <!-- ── Mode: Camera (Preview) ─────────────────────────── -->
            <div t-if="state.mode === 'camera'" class="text-center">
                <div class="position-relative d-inline-block mb-3" style="max-width: 480px; width: 100%;">
                    <video t-ref="video"
                           t-att-class="'rounded-3 w-100' + (state.facingMode === 'user' ? '' : '')"
                           autoplay="autoplay"
                           playsinline="playsinline"
                           style="transform: scaleX(-1); background: #000; max-height: 400px; object-fit: cover;"/>
                    <div class="position-absolute bottom-0 start-0 end-0 p-2 text-center"
                         style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                        <small class="text-white">
                            <i class="fa fa-map-marker"/>
                            <t t-esc="state.latitude?.toFixed(5)"/>
                            , <t t-esc="state.longitude?.toFixed(5)"/>
                        </small>
                    </div>
                </div>
                <div class="d-flex justify-content-center gap-3">
                    <button class="btn btn-outline-secondary btn-lg px-4"
                            t-on-click="onSwitchCamera">
                        <i class="fa fa-refresh"/>
                    </button>
                    <button class="btn btn-primary btn-lg px-5"
                            t-on-click="onCapture">
                        <i class="fa fa-camera me-2"/>
                        Ambil Foto
                    </button>
                    <button class="btn btn-outline-danger btn-lg px-4"
                            t-on-click="onReset">
                        <i class="fa fa-times"/>
                    </button>
                </div>
            </div>

            <!-- ── Mode: Capturing (Preview Photo) ────────────────── -->
            <div t-if="state.mode === 'capturing'" class="text-center">
                <div class="mb-3">
                    <img t-att-src="state.photoData"
                         class="img-fluid rounded-3 shadow"
                         style="max-height: 400px;"/>
                </div>
                <p class="text-muted mb-3">
                    <small>Foto sudah diambil. Kirim atau ambil ulang?</small>
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <button class="btn btn-outline-secondary btn-lg px-4"
                            t-on-click="onRetake">
                        <i class="fa fa-redo me-2"/>
                        Ambil Ulang
                    </button>
                    <button class="btn btn-success btn-lg px-5"
                            t-on-click="onSubmit">
                        <i class="fa fa-paper-plane me-2"/>
                        Kirim Absensi
                    </button>
                </div>
            </div>

            <!-- ── Mode: Sending ──────────────────────────────────── -->
            <div t-if="state.mode === 'sending'" class="text-center py-5">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted">Mengirim data absensi...</p>
            </div>

            <!-- ── Mode: Done (Success) ───────────────────────────── -->
            <div t-if="state.mode === 'done'" class="text-center py-4">
                <div class="mb-3">
                    <i class="fa fa-check-circle text-success" style="font-size: 4rem;"/>
                </div>
                <h4 class="text-success fw-bold mb-2">Absensi Berhasil!</h4>
                <div class="card mx-auto mb-3" style="max-width: 400px;">
                    <div class="card-body">
                        <div class="row text-start">
                            <div class="col-6 text-muted">Karyawan:</div>
                            <div class="col-6 fw-bold" t-esc="state.result?.employee"/>
                            <div class="col-6 text-muted">Aksi:</div>
                            <div class="col-6">
                                <span class="badge"
                                      t-att-class="state.result?.action === 'check_out' ? 'bg-warning' : 'bg-success'"
                                      t-esc="state.result?.action === 'check_out' ? 'Check Out' : 'Check In'"/>
                            </div>
                            <div class="col-6 text-muted">Zona:</div>
                            <div class="col-6" t-esc="state.result?.zone"/>
                            <div class="col-6 text-muted">Waktu:</div>
                            <div class="col-6" t-esc="state.result?.timestamp"/>
                        </div>
                    </div>
                </div>
                <button class="btn btn-primary btn-lg px-5"
                        t-on-click="onReset">
                    <i class="fa fa-redo me-2"/>
                    Absensi Lagi
                </button>
            </div>

            <!-- ── Error ──────────────────────────────────────────── -->
            <div t-if="state.errorMsg" class="alert alert-danger mt-3">
                <i class="fa fa-exclamation-circle me-2"/>
                <t t-esc="state.errorMsg"/>
            </div>

            <!-- Hidden canvas for photo capture -->
            <canvas t-ref="canvas" style="display: none;"/>
        </div>
    </t>

</templates>
