        <record id="demo_device_zkteco" model="hr.attendance.device">
            <field name="name">ZKTeco Lobby</field>
            <field name="brand">zteko</field>
            <field name="connection_type">csv_import</field>
            <field name="location">Lobi Utama</field>
            <field name="employee_mapping">pin</field>
            <field name="state">offline</field>
        </record>

        <record id="demo_device_generic" model="hr.attendance.device">
            <field name="name">ATT2000 Gudang</field>
