            <field name="device_id" ref="demo_device_generic"/>
            <field name="employee_pin">9999</field>
            <field name="timestamp" eval="(DateTime.today() - relativedelta(days=1)).strftime('%Y-%m-%d') + ' 08:00:00'"/>
            <field name="punch_type">0</field>
            <field name="verify_mode">1</field>
            <field name="state">error</field>
            <field name="error_message">PIN tidak ditemukan: 9999</field>
        </record>

        <!-- ── Demo Overtime ──────────────────────────────────────────────── -->

        <record id="demo_overtime_1" model="hr.overtime">
            <field name="employee_id" ref="demo_employee_1"/>
            <field name="overtime_date" eval="(DateTime.today() - relativedelta(days=2)).date()"/>
            <field name="start_time">17.0</field>
            <field name="end_time">20.0</field>
            <field name="overtime_type">weekday</field>
            <field name="reason">Menyelesaikan laporan bulanan</field>
            <field name="activity_description">&lt;p&gt;Menyiapkan dan menyelesaikan laporan penjualan bulanan untuk presentasi besok.&lt;/p&gt;</field>
            <field name="state">approved</field>
            <field name="approved_date" eval="(DateTime.today() - relativedelta(days=1)).strftime('%Y-%m-%d') + ' 09:00:00'"/>
        </record>

        <record id="demo_overtime_2" model="hr.overtime">
            <field name="employee_id" ref="demo_employee_3"/>
            <field name="overtime_date" eval="(DateTime.today() - relativedelta(days=1)).date()"/>
            <field name="start_time">18.0</field>
            <field name="end_time">21.5</field>
            <field name="overtime_type">weekday</field>
            <field name="reason">Deploy aplikasi ke production</field>
            <field name="activity_description">&lt;p&gt;Melakukan deploy aplikasi baru ke server production setelah jam kerja.&lt;/p&gt;</field>
            <field name="state">submitted</field>
        </record>

        <!-- ── Demo Shift Assignment ──────────────────────────────────────── -->

        <record id="demo_shift_assign_1" model="hr.shift.assign">
            <field name="employee_id" ref="demo_employee_1"/>
            <field name="rotation_id" ref="rotation_3shift_weekly"/>
            <field name="date_from" eval="(DateTime.today() - relativedelta(days=7)).date()"/>
            <field name="date_to" eval="(DateTime.today() + relativedelta(days=21)).date()"/>
            <field name="state">confirmed</field>
        </record>

