            <field name="state">offline</field>
        </record>

        <!-- ── Demo Attendance Logs ───────────────────────────────────────── -->

        <record id="demo_log_1" model="hr.attendance.device.log">
            <field name="device_id" ref="demo_device_zkteco"/>
            <field name="employee_id" ref="demo_employee_1"/>
            <field name="employee_pin">1001</field>
            <field name="timestamp" eval="(DateTime.today() - relativedelta(days=1)).strftime('%Y-%m-%d') + ' 08:05:00'"/>
            <field name="punch_type">0</field>
            <field name="verify_mode">1</field>
            <field name="state">matched</field>
        </record>

        <record id="demo_log_2" model="hr.attendance.device.log">
            <field name="device_id" ref="demo_device_zkteco"/>
            <field name="employee_id" ref="demo_employee_1"/>
            <field name="employee_pin">1001</field>
            <field name="timestamp" eval="(DateTime.today() - relativedelta(days=1)).strftime('%Y-%m-%d') + ' 17:10:00'"/>
            <field name="punch_type">1</field>
            <field name="verify_mode">1</field>
            <field name="state">matched</field>
        </record>

