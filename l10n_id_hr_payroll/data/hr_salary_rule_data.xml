<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             KATEGORI SALARY RULES
             ================================================================ -->

        <record id="hr_salary_rule_category_basic_id" model="hr.salary.rule.category">
            <field name="name">Penghasilan Bruto</field>
            <field name="code">BRUTO</field>
        </record>

        <record id="hr_salary_rule_category_deduction_id" model="hr.salary.rule.category">
            <field name="name">Potongan Karyawan</field>
            <field name="code">POTONG</field>
        </record>

        <record id="hr_salary_rule_category_employer_id" model="hr.salary.rule.category">
            <field name="name">Kontribusi Perusahaan</field>
            <field name="code">COMP</field>
        </record>

        <!-- ================================================================
             SALARY RULES — PENGHASILAN
             ================================================================ -->

        <!-- Gaji Pokok -->
        <record id="hr_salary_rule_basic" model="hr.salary.rule">
            <field name="name">Gaji Pokok</field>
            <field name="code">IDN_BASIC</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.wage</field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- Tunjangan Tetap -->
        <record id="hr_salary_rule_tunj_tetap" model="hr.salary.rule">
            <field name="name">Tunjangan Tetap</field>
            <field name="code">IDN_TUNJ_TETAP</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.x_tunjangan_tetap or 0.0</field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- Tunjangan Tidak Tetap -->
        <record id="hr_salary_rule_tunj_tidak_tetap" model="hr.salary.rule">
            <field name="name">Tunjangan Tidak Tetap</field>
            <field name="code">IDN_TUNJ_TIDAK_TETAP</field>
            <field name="sequence">30</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.x_tunjangan_tidak_tetap or 0.0</field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- Upah Lembur -->
        <record id="hr_salary_rule_overtime" model="hr.salary.rule">
            <field name="name">Upah Lembur</field>
            <field name="code">IDN_OVERTIME</field>
            <field name="sequence">40</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Ambil total lembur yang sudah approved dan belum masuk payslip
overtime_recs = env['hr.overtime'].search([
    ('employee_id', '=', employee.id),
    ('state', '=', 'approved'),
    ('payslip_id', '=', False),
    ('overtime_date', '&gt;=', payslip.date_from),
    ('overtime_date', '&lt;=', payslip.date_to),
])
result = sum(overtime_recs.mapped('overtime_pay'))
# Link lembur ke payslip
overtime_recs.write({'payslip_id': payslip.id})
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- THR (Tunjangan Hari Raya) -->
        <record id="hr_salary_rule_thr" model="hr.salary.rule">
            <field name="name">Tunjangan Hari Raya (THR)</field>
            <field name="code">IDN_THR</field>
            <field name="sequence">50</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = payslip.include_thr</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = payslip.thr_amount or 0.0</field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- Bonus -->
        <record id="hr_salary_rule_bonus" model="hr.salary.rule">
            <field name="name">Bonus</field>
            <field name="code">IDN_BONUS</field>
            <field name="sequence">55</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = inputs.IDN_BONUS.amount if inputs.IDN_BONUS else 0.0</field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- ================================================================
             SALARY RULES — POTONGAN KARYAWAN
             ================================================================ -->

        <!-- BPJS Kesehatan — Karyawan 1% -->
        <record id="hr_salary_rule_bpjs_kes_emp" model="hr.salary.rule">
            <field name="name">BPJS Kesehatan (Karyawan 1%)</field>
            <field name="code">IDN_BPJS_KES_EMP</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="hr_salary_rule_category_deduction_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = categories.BRUTO
upah_cap = min(upah_dasar, 12000000)
result = -(upah_cap * 0.01)
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JHT — Karyawan 2% -->
        <record id="hr_salary_rule_bpjs_tk_jht_emp" model="hr.salary.rule">
            <field name="name">JHT Karyawan (2%)</field>
            <field name="code">IDN_BPJS_TK_JHT_EMP</field>
            <field name="sequence">110</field>
            <field name="category_id" ref="hr_salary_rule_category_deduction_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
result = -(upah_dasar * 0.02)
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JP — Karyawan 1% (max upah Rp 9.077.600) -->
        <record id="hr_salary_rule_bpjs_tk_jp_emp" model="hr.salary.rule">
            <field name="name">JP Karyawan (1%)</field>
            <field name="code">IDN_BPJS_TK_JP_EMP</field>
            <field name="sequence">120</field>
            <field name="category_id" ref="hr_salary_rule_category_deduction_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
upah_cap = min(upah_dasar, 9077600)
result = -(upah_cap * 0.01)
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- PPh 21 -->
        <record id="hr_salary_rule_pph21" model="hr.salary.rule">
            <field name="name">PPh 21</field>
            <field name="code">IDN_PPH21</field>
            <field name="sequence">130</field>
            <field name="category_id" ref="hr_salary_rule_category_deduction_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# Ambil dari pph21_ids yang sudah dihitung di compute_sheet
if payslip.pph21_ids:
    result = -(payslip.pph21_ids[0].pph21_final)
else:
    result = 0.0
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- ================================================================
             SALARY RULES — KONTRIBUSI PERUSAHAAN
             ================================================================ -->

        <!-- BPJS Kesehatan — Perusahaan 4% -->
        <record id="hr_salary_rule_bpjs_kes_comp" model="hr.salary.rule">
            <field name="name">BPJS Kesehatan Perusahaan (4%)</field>
            <field name="code">IDN_BPJS_KES_COMP</field>
            <field name="sequence">200</field>
            <field name="category_id" ref="hr_salary_rule_category_employer_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
upah_cap = min(upah_dasar, 12000000)
result = upah_cap * 0.04
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JHT — Perusahaan 3.7% -->
        <record id="hr_salary_rule_bpjs_tk_jht_comp" model="hr.salary.rule">
            <field name="name">JHT Perusahaan (3.7%)</field>
            <field name="code">IDN_BPJS_TK_JHT_COMP</field>
            <field name="sequence">210</field>
            <field name="category_id" ref="hr_salary_rule_category_employer_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
result = upah_dasar * 0.037
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JP — Perusahaan 2% (max upah Rp 9.077.600) -->
        <record id="hr_salary_rule_bpjs_tk_jp_comp" model="hr.salary.rule">
            <field name="name">JP Perusahaan (2%)</field>
            <field name="code">IDN_BPJS_TK_JP_COMP</field>
            <field name="sequence">220</field>
            <field name="category_id" ref="hr_salary_rule_category_employer_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
upah_cap = min(upah_dasar, 9077600)
result = upah_cap * 0.02
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JKK — Perusahaan (rate sesuai kelompok risiko) -->
        <record id="hr_salary_rule_bpjs_tk_jkk" model="hr.salary.rule">
            <field name="name">JKK Perusahaan (rate per risiko)</field>
            <field name="code">IDN_BPJS_TK_JKK</field>
            <field name="sequence">230</field>
            <field name="category_id" ref="hr_salary_rule_category_employer_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
jkk_rate = employee.bpjs_tk_jkk_rate or 0.0024
result = upah_dasar * jkk_rate
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- JKM — Perusahaan 0.30% -->
        <record id="hr_salary_rule_bpjs_tk_jkm" model="hr.salary.rule">
            <field name="name">JKM Perusahaan (0.30%)</field>
            <field name="code">IDN_BPJS_TK_JKM</field>
            <field name="sequence">240</field>
            <field name="category_id" ref="hr_salary_rule_category_employer_id"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
upah_dasar = payslip.line_ids.filtered(lambda l: l.code == 'IDN_BASIC').total
upah_dasar += payslip.line_ids.filtered(lambda l: l.code == 'IDN_TUNJ_TETAP').total
result = upah_dasar * 0.003
            </field>
            <field name="struct_id" ref="structure_indonesian_employee"/>
        </record>

        <!-- ================================================================
             SEQUENCE
             ================================================================ -->

        <record id="seq_hr_overtime" model="ir.sequence">
            <field name="name">Nomor Pengajuan Lembur</field>
            <field name="code">hr.overtime</field>
            <field name="prefix">OT/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_hr_thr" model="ir.sequence">
            <field name="name">Nomor THR</field>
            <field name="code">hr.thr</field>
            <field name="prefix">THR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
