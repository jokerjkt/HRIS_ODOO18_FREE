<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Jenis Cuti sesuai regulasi Indonesia
             Referensi: UU Ketenagakerjaan No. 13 Tahun 2003
                        UU Cipta Kerja No. 11 Tahun 2020
             ================================================================ -->

        <!-- Cuti Tahunan — 12 hari kerja per tahun -->
        <record id="holiday_status_annual" model="hr.leave.type">
            <field name="name">Cuti Tahunan</field>
            <field name="requires_allocation">yes</field>
            <field name="time_type">leave</field>
            <field name="color">1</field>
        </record>

        <!-- Cuti Sakit -->
        <record id="holiday_status_sick" model="hr.leave.type">
            <field name="name">Cuti Sakit</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">leave</field>
            <field name="color">2</field>
        </record>

        <!-- Cuti Melahirkan — 3 bulan (90 hari) -->
        <record id="holiday_status_maternity" model="hr.leave.type">
            <field name="name">Cuti Melahirkan</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">leave</field>
            <field name="color">4</field>
        </record>

        <!-- Cuti Haid — 2 hari pertama masa haid -->
        <record id="holiday_status_menstrual" model="hr.leave.type">
            <field name="name">Cuti Haid</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">leave</field>
            <field name="color">9</field>
        </record>

        <!-- Cuti Menikah — 3 hari kerja -->
        <record id="holiday_status_marriage" model="hr.leave.type">
            <field name="name">Cuti Menikah</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">leave</field>
            <field name="color">6</field>
        </record>

        <!-- Cuti Anggota Keluarga Meninggal — 2 hari kerja -->
        <record id="holiday_status_bereavement" model="hr.leave.type">
            <field name="name">Cuti Anggota Keluarga Meninggal</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">leave</field>
            <field name="color">5</field>
        </record>

        <!-- Cuti Ibadah (Haji/Umroh) -->
        <record id="holiday_status_pilgrimage" model="hr.leave.type">
            <field name="name">Cuti Ibadah Haji/Umroh</field>
            <field name="requires_allocation">yes</field>
            <field name="time_type">leave</field>
            <field name="color">7</field>
        </record>

        <!-- Cuti Tanpa Gaji (Unpaid Leave) -->
        <record id="holiday_status_unpaid" model="hr.leave.type">
            <field name="name">Cuti Tanpa Gaji</field>
            <field name="requires_allocation">no</field>
            <field name="time_type">other</field>
            <field name="color">8</field>
        </record>

    </data>
</odoo>
