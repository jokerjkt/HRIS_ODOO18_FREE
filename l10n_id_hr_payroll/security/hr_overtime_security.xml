<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Security Groups untuk Overtime
             ================================================================ -->

        <record id="group_hr_overtime_user" model="res.groups">
            <field name="name">Pengguna Lembur</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_hr_overtime_manager" model="res.groups">
            <field name="name">Manajer Lembur</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_overtime_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- ================================================================
             Record Rules — Overtime
             ================================================================ -->

        <!-- Karyawan hanya bisa lihat lembur milik sendiri -->
        <record id="rule_overtime_employee_own" model="ir.rule">
            <field name="name">Lembur: Karyawan hanya lihat milik sendiri</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="groups" eval="[(4, ref('group_hr_overtime_user'))]"/>
            <field name="domain_force">[
                '|',
                ('employee_id.user_id', '=', user.id),
                ('manager_id.user_id', '=', user.id)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager bisa lihat semua lembur -->
        <record id="rule_overtime_manager_all" model="ir.rule">
            <field name="name">Lembur: Manager lihat semua</field>
            <field name="model_id" ref="model_hr_overtime"/>
            <field name="groups" eval="[(4, ref('group_hr_overtime_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
