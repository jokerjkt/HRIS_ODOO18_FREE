<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Record Rules — Data Isolation
             Users see only their own data; managers/admins see all.
             ================================================================ -->

        <!-- ── Payslip: Users see own, Managers see all ──────────────────── -->
        <record id="rule_payslip_user_own" model="ir.rule">
            <field name="name">Payslip: User sees own only</field>
            <field name="model_id" ref="model_hr_payslip"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_user'))]"/>
        </record>

        <record id="rule_payslip_manager_all" model="ir.rule">
            <field name="name">Payslip: Manager sees all</field>
            <field name="model_id" ref="model_hr_payslip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_admin'))]"/>
        </record>

        <!-- ── THR: Users see own, Admins see all ─────────────────────── -->
        <record id="rule_thr_user_own" model="ir.rule">
