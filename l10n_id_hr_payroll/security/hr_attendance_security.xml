            <field name="name">THR: Admin sees all</field>
            <field name="model_id" ref="model_hr_thr"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_admin'))]"/>
        </record>

