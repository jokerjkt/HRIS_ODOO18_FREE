        </record>

        <record id="rule_bpjs_manager_all" model="ir.rule">
            <field name="name">BPJS: Admin sees all</field>
            <field name="model_id" ref="model_hr_bpjs"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_admin'))]"/>
        </record>

        <!-- ── Attendance Device Log: Admin only ──────────────────────────── -->
        <record id="rule_attendance_log_admin" model="ir.rule">
            <field name="name">Attendance Log: Admin sees all</field>
            <field name="model_id" ref="model_hr_attendance_device_log"/>
