<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Shift Assign — Form View
             ================================================================ -->

        <record id="view_hr_shift_assign_form" model="ir.ui.view">
            <field name="name">hr.shift.assign.form</field>
            <field name="model">hr.shift.assign</field>
            <field name="arch" type="xml">
                <form string="Assign Shift">
                    <header>
                        <button name="action_generate_daily" type="object"
                                string="Generate Jadwal" class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_done" type="object"
                                string="Selesai" class="btn-success"
                                invisible="state != 'confirmed'"/>
                        <button name="action_cancel" type="object"
                                string="Reset" class="btn-secondary"
                                invisible="state in ('done',)"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,done"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Informasi Karyawan">
                                <field name="employee_id"/>
                                <field name="department_id" readonly="1"/>
                            </group>
                            <group string="Pengaturan Shift">
                                <field name="rotation_id"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                                <field name="daily_count" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_button_box" name="buttons">
                        <button name="%(action_hr_shift_daily)d" type="action"
                                class="oe_stat_button" icon="fa-calendar">
                            <div class="o_stat_info">
                                <field name="daily_count" class="o_stat_value"/>
                                <span class="o_stat_text">Jadwal</span>
                            </div>
                        </button>
                    </div>
                </form>
            </field>
        </record>

        <!-- ================================================================
             Shift Assign — List View
             ================================================================ -->

        <record id="view_hr_shift_assign_list" model="ir.ui.view">
            <field name="name">hr.shift.assign.list</field>
            <field name="model">hr.shift.assign</field>
            <field name="arch" type="xml">
                <list string="Assign Shift"
                      decoration-success="state == 'done'"
                      decoration-warning="state == 'confirmed'"
                      decoration-muted="state == 'draft'">
                    <field name="employee_id"/>
                    <field name="department_id" optional="show"/>
                    <field name="rotation_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="daily_count" width="100"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'done'"
                           decoration-warning="state == 'confirmed'"
                           decoration-muted="state == 'draft'"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             Shift Assign — Search View
             ================================================================ -->

        <record id="view_hr_shift_assign_search" model="ir.ui.view">
            <field name="name">hr.shift.assign.search</field>
            <field name="model">hr.shift.assign</field>
            <field name="arch" type="xml">
                <search string="Cari Assign Shift">
                    <field name="employee_id"/>
                    <field name="rotation_id"/>
                    <field name="department_id"/>
                    <separator/>
                    <filter string="Draft" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Dikonfirmasi" name="filter_confirmed"
                            domain="[('state', '=', 'confirmed')]"/>
                    <filter string="Selesai" name="filter_done"
                            domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <group expand="0" string="Kelompokkan Berdasarkan">
                        <filter string="Karyawan" name="group_employee"
                                context="{'group_by': 'employee_id'}"/>
                        <filter string="Departemen" name="group_department"
                                context="{'group_by': 'department_id'}"/>
                        <filter string="Pola Rotasi" name="group_rotation"
                                context="{'group_by': 'rotation_id'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================================================================
             Shift Assign — Action
             ================================================================ -->

        <record id="action_hr_shift_assign" model="ir.actions.act_window">
            <field name="name">Assign Shift</field>
            <field name="res_model">hr.shift.assign</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_shift_assign_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Belum ada assign shift!
                </p>
                <p>
                    Assign pola rotasi shift ke karyawan di sini, lalu generate jadwal harian.
                </p>
            </field>
        </record>

    </data>
</odoo>
