<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Employee Form — Tab Informasi Indonesia (SAP Fiori Pattern)
             ================================================================ -->

        <record id="view_employee_form_indonesia" model="ir.ui.view">
            <field name="name">hr.employee.form.indonesia</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='personal_information']" position="after">
                    <page name="indonesia_info" string="Indonesia HR">

                        <!-- ═══ Section: Identitas & Perpajakan ═══ -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">
                                <i class="fa fa-id-card"/> Identitas &amp; Perpajakan
                            </div>
                            <div class="row">
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">NIK (KTP)</div>
                                        <field name="nik" placeholder="16 digit NIK"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">NPWP</div>
                                        <field name="npwp" placeholder="XX.XXX.XXX.X-XXX.XXX"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Status NPWP</div>
                                        <field name="npwp_has" readonly="1"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Tipe Kontrak</div>
                                        <field name="employee_contract_type"/>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Status PTKP</div>
                                        <field name="ptkp_status"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Nilai PTKP (Rp/tahun)</div>
                                        <field name="ptkp_amount" widget="monetary" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══ Section: BPJS Ketenagakerjaan ═══ -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">
                                <i class="fa fa-shield"/> BPJS Ketenagakerjaan
                            </div>
                            <div class="row">
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">No. Peserta BPJS TK</div>
                                        <field name="bpjs_tk_no" placeholder="Nomor Peserta BPJS TK"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Kelompok Risiko JKK</div>
                                        <field name="bpjs_tk_jkk_class"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Rate JKK (%)</div>
                                        <field name="bpjs_tk_jkk_rate" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══ Section: BPJS Kesehatan ═══ -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">
                                <i class="fa fa-heartbeat"/> BPJS Kesehatan
                            </div>
                            <div class="row">
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">No. Peserta BPJS Kes</div>
                                        <field name="bpjs_kes_no"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Kelas BPJS Kesehatan</div>
                                        <field name="bpjs_kes_class"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══ Section: Masa Kerja & THR ═══ -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">
                                <i class="fa fa-calendar"/> Masa Kerja &amp; THR
                            </div>
                            <div class="row">
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Tanggal Bergabung</div>
                                        <field name="join_date"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Masa Kerja (Bulan)</div>
                                        <field name="tenure_months" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══ Section: Data Bank ═══ -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">
                                <i class="fa fa-university"/> Data Bank (Transfer Gaji)
                            </div>
                            <div class="row">
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Nama Bank</div>
                                        <field name="bank_name" placeholder="BCA / Mandiri / BRI / BNI"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Cabang</div>
                                        <field name="bank_branch" placeholder="Cabang bank"/>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-6">
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">No. Rekening</div>
                                        <field name="bank_account_number" placeholder="Nomor rekening"/>
                                    </div>
                                    <div class="sapFormGroup">
                                        <div class="sapFormGroup__label">Atas Nama</div>
                                        <field name="bank_account_name" placeholder="Nama pemegang rekening"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </page>
                </xpath>

            </field>
        </record>

        <!-- ================================================================
             Employee List — Tambah kolom NIK
             ================================================================ -->

        <record id="view_employee_list_indonesia" model="ir.ui.view">
            <field name="name">hr.employee.list.indonesia</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='job_id']" position="after">
                    <field name="nik" optional="show"/>
                    <field name="ptkp_status" optional="show"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
