<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             My Dashboard — Form View
             ================================================================ -->

        <record id="view_hr_my_dashboard_form" model="ir.ui.view">
            <field name="name">hr.my.dashboard.form</field>
            <field name="model">hr.my.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard Saya" create="false" edit="false">
                    <sheet>
                        <div class="l10n_id_dashboard">

                            <!-- Welcome Header -->
                            <div class="sapFormHeader">
                                <h1>
                                    <span>Selamat Datang, <field name="employee_name" readonly="1" nolabel="1"/></span>
                                </h1>
                                <p>
                                    <field name="employee_department" readonly="1" nolabel="1"/>
                                    <span> • </span>
                                    <field name="employee_job" readonly="1" nolabel="1"/>
                                    <span> • NIK: </span>
                                    <field name="employee_nik" readonly="1" nolabel="1"/>
                                </p>
                                <p>
                                    <span>NPWP: </span>
                                    <field name="employee_npwp" readonly="1" nolabel="1"/>
                                    <span> • PTKP: </span>
                                    <field name="employee_ptkp" readonly="1" nolabel="1"/>
                                    <span> • Bank: </span>
                                    <field name="employee_bank_name" readonly="1" nolabel="1"/>
                                    <span> • Rekening: </span>
                                    <field name="employee_bank_account" readonly="1" nolabel="1"/>
                                </p>
                            </div>

                            <!-- Trial Banner -->
                            <div class="sapTrialBanner sapTrialBanner--danger" role="alert"
                                 invisible="not trial_expired">
                                <strong>Masa Uji Coba Berakhir</strong> — Hubungi vendor untuk lisensi.
                            </div>

                            <!-- ════════════════════════════════════════════════════════ -->
                            <!-- ROW 1: KPI Tiles                                         -->
                            <!-- ════════════════════════════════════════════════════════ -->
                            <div class="sapKpiRow">

                                <!-- Slip Gaji -->
                                <div class="sapKpiTile sapKpiTile--positive">
                                    <div class="sapKpiTile__title">Slip Gaji</div>
                                    <div class="sapKpiTile__value">
                                        <field name="my_payslip_count" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">
                                        <span class="sapKpiTile__detail">
                                            <field name="my_payslip_draft" readonly="1" nolabel="1"/> Draft
                                        </span>
                                        <span class="sapKpiTile__detail">
                                            <field name="my_payslip_done" readonly="1" nolabel="1"/> Selesai
                                        </span>
                                    </div>
                                    <div class="sapKpiTile__trend">
                                        <div class="sapQuickActions">
                                            <a class="sapQuickAction"
                                               name="action_open_my_payslips" type="object">
                                                <span class="sapQuickAction__icon"><i class="fa fa-eye"/></span>
                                                <span class="sapQuickAction__label">Lihat Slip Gaji</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Lembur -->
                                <div class="sapKpiTile sapKpiTile--critical">
                                    <div class="sapKpiTile__title">Lembur</div>
                                    <div class="sapKpiTile__value">
                                        <field name="my_overtime_total" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">
                                        <span class="sapKpiTile__detail">
                                            <field name="my_overtime_pending" readonly="1" nolabel="1"/> Pending
                                        </span>
                                        <span class="sapKpiTile__detail">
                                            <field name="my_overtime_approved" readonly="1" nolabel="1"/> Disetujui
                                        </span>
                                    </div>
                                    <div class="sapKpiTile__trend">
                                        <div class="sapQuickActions">
                                            <a class="sapQuickAction"
                                               name="action_create_overtime" type="object">
                                                <span class="sapQuickAction__icon"><i class="fa fa-plus"/></span>
                                                <span class="sapQuickAction__label">Buat Lembur</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cuti -->
                                <div class="sapKpiTile sapKpiTile--info">
                                    <div class="sapKpiTile__title">Cuti</div>
                                    <div class="sapKpiTile__value">
                                        <field name="my_leave_total" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">
                                        <span class="sapKpiTile__detail">
                                            <field name="my_leave_pending" readonly="1" nolabel="1"/> Pending
                                        </span>
                                        <span class="sapKpiTile__detail">
                                            <field name="my_leave_approved_days" readonly="1" nolabel="1"/> Hari Disetujui
                                        </span>
                                    </div>
                                    <div class="sapKpiTile__trend">
                                        <div class="sapQuickActions">
                                            <a class="sapQuickAction"
                                               name="action_create_leave" type="object">
                                                <span class="sapQuickAction__icon"><i class="fa fa-plus"/></span>
                                                <span class="sapQuickAction__label">Ajukan Cuti</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Expense -->
                                <div class="sapKpiTile sapKpiTile--neutral">
                                    <div class="sapKpiTile__title">Expense</div>
                                    <div class="sapKpiTile__value">
                                        <field name="my_expense_total" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">
                                        <span class="sapKpiTile__detail">
                                            <field name="my_expense_draft" readonly="1" nolabel="1"/> Draft
                                        </span>
                                    </div>
                                    <div class="sapKpiTile__trend">
                                        <div class="sapQuickActions">
                                            <a class="sapQuickAction"
                                               name="action_create_expense" type="object">
                                                <span class="sapQuickAction__icon"><i class="fa fa-plus"/></span>
                                                <span class="sapQuickAction__label">Ajukan Expense</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!-- ════════════════════════════════════════════════════════ -->
                            <!-- ROW 2: Data Cards — Attendance & Shift                    -->
                            <!-- ════════════════════════════════════════════════════════ -->
                            <div class="sapKpiRow">

                                <!-- Absensi -->
                                <div class="sapDataCard">
                                    <div class="sapDataCard__header">
                                        <span class="sapSectionTitle"><i class="fa fa-clock-o"/> Absensi Saya</span>
                                    </div>
                                    <div class="sapDataCard__body">
                                        <div class="sapDataCard__stats">
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_attendance_count" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Total Absensi</div>
                                            </div>
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_total_work_hours" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Jam Kerja</div>
                                            </div>
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_last_checkin" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Check-in Terakhir</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="sapDataCard__header">
                                        <div class="sapQuickActions">
                                            <a class="sapQuickAction"
                                               name="action_open_my_attendance" type="object">
                                                <span class="sapQuickAction__icon"><i class="fa fa-eye"/></span>
                                                <span class="sapQuickAction__label">Lihat Absensi</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <!-- Shift -->
                                <div class="sapDataCard">
                                    <div class="sapDataCard__header">
                                        <span class="sapSectionTitle"><i class="fa fa-calendar"/> Shift Saya</span>
                                    </div>
                                    <div class="sapDataCard__body">
                                        <div class="sapDataCard__stats">
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_shift_name" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Shift Saat Ini</div>
                                            </div>
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_shift_hours" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Jam Kerja</div>
                                            </div>
                                            <div>
                                                <div class="sapKpiTile__value">
                                                    <field name="my_shift_days" readonly="1" nolabel="1"/>
                                                </div>
                                                <div class="sapKpiTile__subtitle">Hari Kerja</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================
             My Dashboard — Action
             ================================================================ -->

        <record id="action_hr_my_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard Saya</field>
            <field name="res_model">hr.my.dashboard</field>
            <field name="view_mode">form</field>
            <field name="views" eval="[(ref('view_hr_my_dashboard_form'), 'form')]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Selamat Datang di Dashboard Personal Anda!
                </p>
            </field>
        </record>

    </data>
</odoo>
