<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             My Dashboard — Form View
             ================================================================ -->

        <record id="view_hr_my_dashboard_form" model="ir.ui.view">
            <field name="name">hr.my.dashboard.form</field>
            <field name="model">hr.my.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard Saya" create="false" edit="false">
                    <sheet>
                        <div class="container-fluid">
                        <div class="oe_title mb-4 text-center">
                            <h1>
                                <span>Selamat Datang, <field name="employee_name" readonly="1" nolabel="1"/></span>
                            </h1>
                            <p class="text-muted mb-1">
                                <field name="employee_department" readonly="1" nolabel="1"/>
                                <span> • </span>
                                <field name="employee_job" readonly="1" nolabel="1"/>
                                <span> • NIK: </span>
                                <field name="employee_nik" readonly="1" nolabel="1"/>
                            </p>
                            <p class="text-muted mb-0">
                                <span>NPWP: </span>
                                <field name="employee_npwp" readonly="1" nolabel="1"/>
                                <span> • PTKP: </span>
                                <field name="employee_ptkp" readonly="1" nolabel="1"/>
                                <span> • Bank: </span>
                                <field name="employee_bank_name" readonly="1" nolabel="1"/>
                                <span> • Rekening: </span>
                                <field name="employee_bank_account" readonly="1" nolabel="1"/>
                            </p>
                        </div>

                        <!-- Trial Banner -->
                        <div class="alert alert-danger text-center" role="alert"
                             invisible="not trial_expired">
                            <strong>Masa Uji Coba Berakhir</strong> — Hubungi vendor untuk lisensi.
                        </div>

                        <!-- ════════════════════════════════════════════════════════ -->
                        <!-- ROW 1: Quick Stats                                        -->
                        <!-- ════════════════════════════════════════════════════════ -->
                        <div class="row mb-4">
                            <!-- Slip Gaji -->
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-success h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-file-text-o fa-3x text-success mb-2"/>
                                        <h2 class="mb-1 text-success">
                                            <field name="my_payslip_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Slip Gaji</small>
                                        <br/>
                                        <span class="badge bg-warning text-dark">
                                            <field name="my_payslip_draft" readonly="1" nolabel="1"/> Draft
                                        </span>
                                        <span class="badge bg-success">
                                            <field name="my_payslip_done" readonly="1" nolabel="1"/> Selesai
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-success btn-sm"
                                           name="action_open_my_payslips" type="object">
                                            <i class="fa fa-eye"/> Lihat Slip Gaji
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Lembur -->
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-warning h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-clock-o fa-3x text-warning mb-2"/>
                                        <h2 class="mb-1 text-warning">
                                            <field name="my_overtime_total" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Lembur</small>
                                        <br/>
                                        <span class="badge bg-warning text-dark">
                                            <field name="my_overtime_pending" readonly="1" nolabel="1"/> Pending
                                        </span>
                                        <span class="badge bg-success">
                                            <field name="my_overtime_approved" readonly="1" nolabel="1"/> Disetujui
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-warning btn-sm"
                                           name="action_create_overtime" type="object">
                                            <i class="fa fa-plus"/> Buat Lembur
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Cuti -->
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-info h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-calendar fa-3x text-info mb-2"/>
                                        <h2 class="mb-1 text-info">
                                            <field name="my_leave_total" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Cuti</small>
                                        <br/>
                                        <span class="badge bg-warning text-dark">
                                            <field name="my_leave_pending" readonly="1" nolabel="1"/> Pending
                                        </span>
                                        <span class="badge bg-info">
                                            <field name="my_leave_approved_days" readonly="1" nolabel="1"/> Hari Disetujui
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-info btn-sm"
                                           name="action_create_leave" type="object">
                                            <i class="fa fa-plus"/> Ajukan Cuti
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Expense -->
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-primary h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-receipt fa-3x text-primary mb-2"/>
                                        <h2 class="mb-1 text-primary">
                                            <field name="my_expense_total" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Expense</small>
                                        <br/>
                                        <span class="badge bg-warning text-dark">
                                            <field name="my_expense_draft" readonly="1" nolabel="1"/> Draft
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-primary btn-sm"
                                           name="action_create_expense" type="object">
                                            <i class="fa fa-plus"/> Ajukan Expense
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ════════════════════════════════════════════════════════ -->
                        <!-- ROW 2: Attendance & Shift                                 -->
                        <!-- ════════════════════════════════════════════════════════ -->
                        <div class="row mb-4">
                            <!-- Absensi -->
                            <div class="col-lg-6 mb-3">
                                <div class="card border-secondary h-100 shadow-sm">
                                    <div class="card-header bg-secondary text-white">
                                        <strong><i class="fa fa-clock-o"/> Absensi Saya</strong>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center">
                                            <div class="col-4">
                                                <h3 class="mb-0">
                                                    <field name="my_attendance_count" readonly="1" nolabel="1"/>
                                                </h3>
                                                <small class="text-muted">Total Absensi</small>
                                            </div>
                                            <div class="col-4">
                                                <h3 class="mb-0">
                                                    <field name="my_total_work_hours" readonly="1" nolabel="1"/>
                                                </h3>
                                                <small class="text-muted">Jam Kerja</small>
                                            </div>
                                            <div class="col-4">
                                                <field name="my_last_checkin" readonly="1" nolabel="1"/>
                                                <small class="text-muted d-block">Check-in Terakhir</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           name="action_open_my_attendance" type="object">
                                            <i class="fa fa-eye"/> Lihat Absensi
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- Shift -->
                            <div class="col-lg-6 mb-3">
                                <div class="card border-dark h-100 shadow-sm">
                                    <div class="card-header bg-dark text-white">
                                        <strong><i class="fa fa-calendar"/> Shift Saya</strong>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center">
                                            <div class="col-4">
                                                <h5 class="mb-0">
                                                    <field name="my_shift_name" readonly="1" nolabel="1"/>
                                                </h5>
                                                <small class="text-muted">Shift Saat Ini</small>
                                            </div>
                                            <div class="col-4">
                                                <h5 class="mb-0">
                                                    <field name="my_shift_hours" readonly="1" nolabel="1"/>
                                                </h5>
                                                <small class="text-muted">Jam Kerja</small>
                                            </div>
                                            <div class="col-4">
                                                <h5 class="mb-0">
                                                    <field name="my_shift_days" readonly="1" nolabel="1"/>
                                                </h5>
                                                <small class="text-muted">Hari Kerja</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================
             My Dashboard — Action
             ================================================================ -->

        <record id="action_hr_my_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard Saya</field>
            <field name="res_model">hr.my.dashboard</field>
            <field name="view_mode">form</field>
            <field name="views" eval="[(ref('view_hr_my_dashboard_form'), 'form')]"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Selamat Datang di Dashboard Personal Anda!
                </p>
            </field>
        </record>

    </data>
</odoo>
