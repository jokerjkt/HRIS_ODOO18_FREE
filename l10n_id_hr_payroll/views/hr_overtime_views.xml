<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Overtime — Form View (SAP Fiori Object Page)
             ================================================================ -->

        <record id="view_hr_overtime_form" model="ir.ui.view">
            <field name="name">hr.overtime.form</field>
            <field name="model">hr.overtime</field>
            <field name="arch" type="xml">
                <form string="Pengajuan Lembur">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,submitted,approved"/>
                    </header>
                    <sheet>
                        <!-- Form Header -->
                        <div class="sapFormHeader">
                            <div class="sapFormHeader__left">
                                <div class="sapFormHeader__avatar">
                                    <field name="employee_id" widget="many2one_avatar_employee" readonly="1"/>
                                </div>
                                <div>
                                    <h1 class="sapFormHeader__title">
                                        <field name="employee_id" readonly="1" placeholder="Nama Karyawan"/>
                                    </h1>
                                    <div class="sapFormHeader__subtitle">Lembur</div>
                                </div>
                            </div>
                            <div class="sapFormHeader__actions">
                                <div class="sapFormStatus sapFormStatus--draft" invisible="state != 'draft'">Draft</div>
                                <div class="sapFormStatus sapFormStatus--submitted" invisible="state != 'submitted'">Menunggu Persetujuan</div>
                                <div class="sapFormStatus sapFormStatus--approved" invisible="state != 'approved'">Disetujui</div>
                                <div class="sapFormStatus sapFormStatus--rejected" invisible="state != 'rejected'">Ditolak</div>
                                <div class="sapFormStatus sapFormStatus--cancelled" invisible="state != 'cancelled'">Dibatalkan</div>
                                <button name="action_submit"
                                        string="Submit ke Atasan"
                                        type="object"
                                        class="sapFormHeader__btn sapFormHeader__btn--emphasized"
                                        invisible="state != 'draft'"/>
                                <button name="action_approve"
                                        string="Setujui"
                                        type="object"
                                        class="sapFormHeader__btn sapFormHeader__btn--positive"
                                        groups="l10n_id_hr_payroll.group_hr_overtime_manager"
                                        invisible="state != 'submitted'"/>
                                <button name="action_reject"
                                        string="Tolak"
                                        type="object"
                                        class="sapFormHeader__btn sapFormHeader__btn--negative"
                                        groups="l10n_id_hr_payroll.group_hr_overtime_manager"
                                        invisible="state != 'submitted'"/>
                                <button name="action_cancel"
                                        string="Batalkan"
                                        type="object"
                                        class="sapFormHeader__btn"
                                        invisible="state not in ('draft', 'submitted')"/>
                                <button name="action_reset_draft"
                                        string="Reset ke Draft"
                                        type="object"
                                        class="sapFormHeader__btn"
                                        invisible="state not in ('rejected', 'cancelled')"/>
                            </div>
                        </div>

                        <!-- KPI Summary -->
                        <div class="sapFormSummary">
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--brand">
                                    <i class="fa fa-clock-o"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">Durasi</div>
                                    <div class="sapFormSummary__value">
                                        <field name="duration" readonly="1" string="jam"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--positive">
                                    <i class="fa fa-money"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">Estimasi Upah</div>
                                    <div class="sapFormSummary__value">
                                        <field name="overtime_pay" widget="monetary" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--critical">
                                    <i class="fa fa-calendar"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">Tanggal</div>
                                    <div class="sapFormSummary__value">
                                        <field name="overtime_date" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Informasi Karyawan</div>
                            <group>
                                <group>
                                    <field name="employee_id"
                                           readonly="state != 'draft'"/>
                                    <field name="department_id" readonly="1"/>
                                </group>
                                <group>
                                    <field name="job_id" readonly="1"/>
                                    <field name="manager_id" readonly="1"/>
                                </group>
                            </group>
                        </div>

                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Waktu Lembur</div>
                            <group>
                                <group>
                                    <field name="overtime_date"
                                           readonly="state != 'draft'"/>
                                    <field name="overtime_type"
                                           readonly="state != 'draft'"/>
                                    <field name="start_time" widget="float_time"
                                           readonly="state != 'draft'"/>
                                    <field name="end_time" widget="float_time"
                                           readonly="state != 'draft'"/>
                                </group>
                                <group>
                                    <field name="duration" readonly="1" string="Durasi (jam)"/>
                                    <field name="multiplier_first" readonly="1"/>
                                    <field name="multiplier_next" readonly="1"/>
                                    <field name="overtime_pay" widget="monetary" readonly="1"
                                           string="Estimasi Upah Lembur (Rp)"/>
                                </group>
                            </group>
                        </div>

                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Detail Kegiatan Lembur</div>
                            <group>
                                <field name="reason" placeholder="Alasan singkat lembur..."
                                       readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="activity_description"
                                       placeholder="Uraikan secara detail kegiatan yang dilakukan selama lembur. Contoh: Review laporan keuangan Q2, meeting dengan klien XYZ, pengerjaan fitur A untuk project B..."
                                       widget="html"
                                       readonly="state != 'draft'"
                                       style="min-height: 120px;"/>
                            </group>
                            <group>
                                <field name="result_output"
                                       placeholder="Output/hasil yang dicapai selama lembur..."
                                       readonly="state != 'draft'"/>
                            </group>
                        </div>

                        <div class="sapFormSection"
                             invisible="state in ('draft', 'submitted')">
                            <div class="sapFormSection__title">Informasi Persetujuan</div>
                            <group>
                                <group>
                                    <field name="approved_by" readonly="1"/>
                                    <field name="approved_date" readonly="1"/>
                                </group>
                                <group invisible="state != 'rejected'">
                                    <field name="reject_reason" readonly="1"/>
                                </group>
                            </group>
                        </div>

                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Payslip</div>
                            <group>
                                <field name="payslip_id" readonly="1"/>
                                <field name="is_included_payslip" readonly="1"/>
                            </group>
                        </div>

                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Catatan</div>
                            <field name="notes" placeholder="Catatan tambahan..."/>
                        </div>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================================================================
             Overtime — List View
             ================================================================ -->

        <record id="view_hr_overtime_list" model="ir.ui.view">
            <field name="name">hr.overtime.list</field>
            <field name="model">hr.overtime</field>
            <field name="arch" type="xml">
                <list string="Daftar Pengajuan Lembur"
                      decoration-success="state == 'approved'"
                      decoration-warning="state == 'submitted'"
                      decoration-danger="state == 'rejected'"
                      decoration-muted="state in ('cancelled',)">
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="department_id" optional="show"/>
                    <field name="overtime_date"/>
                    <field name="overtime_type"/>
                    <field name="start_time" widget="float_time"/>
                    <field name="end_time" widget="float_time"/>
                    <field name="duration" string="Jam"/>
                    <field name="reason"/>
                    <field name="overtime_pay" widget="monetary" string="Upah Lembur"/>
                    <field name="manager_id" optional="hide"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'approved'"
                           decoration-warning="state == 'submitted'"
                           decoration-danger="state == 'rejected'"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             Overtime — Kanban View (SAP Fiori Clean Card Pattern)
             ================================================================ -->

        <record id="view_hr_overtime_kanban" model="ir.ui.view">
            <field name="name">hr.overtime.kanban</field>
            <field name="model">hr.overtime</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column"
                        sample="1">
                    <field name="employee_id"/>
                    <field name="overtime_date"/>
                    <field name="duration"/>
                    <field name="overtime_pay"/>
                    <field name="state"/>
                    <field name="reason"/>
                    <field name="name"/>
                    <field name="overtime_type"/>
                    <field name="employee_id" widget="many2one_avatar_employee"/>
                    <field name="start_time" widget="float_time"/>
                    <field name="end_time" widget="float_time"/>
                    <field name="manager_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click sapKanbanCard">
                                <div class="sapKanbanCard__header">
                                    <div class="sapKanbanCard__title">
                                        <strong><field name="employee_id"/></strong>
                                    </div>
                                    <span class="sapKanbanCard__badge"
                                          t-att-class="{
                                              'sapKanbanCard__badge--approved': record.state.raw_value === 'approved',
                                              'sapKanbanCard__badge--submitted': record.state.raw_value === 'submitted',
                                              'sapKanbanCard__badge--rejected': record.state.raw_value === 'rejected',
                                              'sapKanbanCard__badge--draft': record.state.raw_value === 'draft',
                                              'sapKanbanCard__badge--cancelled': record.state.raw_value === 'cancelled'
                                          }">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="sapKanbanCard__body">
                                    <div class="sapKanbanCard__row">
                                        <span class="sapKanbanCard__label">Tanggal</span>
                                        <span class="sapKanbanCard__value">
                                            <field name="overtime_date"/>
                                        </span>
                                    </div>
                                    <div class="sapKanbanCard__row">
                                        <span class="sapKanbanCard__label">Jam</span>
                                        <span class="sapKanbanCard__value">
                                            <field name="start_time" widget="float_time"/> - <field name="end_time" widget="float_time"/>
                                        </span>
                                    </div>
                                    <div class="sapKanbanCard__row">
                                        <span class="sapKanbanCard__label">Durasi</span>
                                        <span class="sapKanbanCard__value">
                                            <field name="duration"/> jam
                                        </span>
                                    </div>
                                    <div class="sapKanbanCard__row">
                                        <span class="sapKanbanCard__label">Upah</span>
                                        <span class="sapKanbanCard__value sapKanbanCard__value--bold">
                                            <field name="overtime_pay" widget="monetary"/>
                                        </span>
                                    </div>
                                    <div class="sapKanbanCard__row" t-if="record.reason.raw_value">
                                        <span class="sapKanbanCard__label">Alasan</span>
                                        <span class="sapKanbanCard__value sapKanbanCard__value--truncate">
                                            <field name="reason"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="sapKanbanCard__footer">
                                    <button name="action_submit"
                                            string="Submit"
                                            type="object"
                                            class="sapKanbanCard__btn sapKanbanCard__btn--primary"
                                            invisible="state != 'draft'"/>
                                    <button name="action_approve"
                                            string="Setujui"
                                            type="object"
                                            class="sapKanbanCard__btn sapKanbanCard__btn--positive"
                                            groups="l10n_id_hr_payroll.group_hr_overtime_manager"
                                            invisible="state != 'submitted'"/>
                                    <button name="action_reject"
                                            string="Tolak"
                                            type="object"
                                            class="sapKanbanCard__btn sapKanbanCard__btn--negative"
                                            groups="l10n_id_hr_payroll.group_hr_overtime_manager"
                                            invisible="state != 'submitted'"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ================================================================
             Overtime — Search View
             ================================================================ -->

        <record id="view_hr_overtime_search" model="ir.ui.view">
            <field name="name">hr.overtime.search</field>
            <field name="model">hr.overtime</field>
            <field name="arch" type="xml">
                <search string="Cari Pengajuan Lembur">
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="overtime_date"/>
                    <field name="reason"/>

                    <filter string="Draft" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Menunggu Persetujuan" name="filter_submitted"
                            domain="[('state', '=', 'submitted')]"/>
                    <filter string="Disetujui" name="filter_approved"
                            domain="[('state', '=', 'approved')]"/>
                    <filter string="Ditolak" name="filter_rejected"
                            domain="[('state', '=', 'rejected')]"/>

                    <separator/>
                    <filter string="Lembur Saya" name="filter_mine"
                            domain="[('employee_id.user_id', '=', uid)]"/>
                    <filter string="Perlu Persetujuan Saya" name="filter_need_approval"
                            domain="[('manager_id.user_id', '=', uid), ('state', '=', 'submitted')]"/>

                    <separator/>
                    <filter string="Hari Ini" name="filter_today"
                            domain="[('overtime_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="Bulan Ini" name="filter_this_month"
                            domain="[('overtime_date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>

                    <group expand="0" string="Kelompokkan Berdasarkan">
                        <filter string="Karyawan" name="group_employee"
                                context="{'group_by': 'employee_id'}"/>
                        <filter string="Departemen" name="group_department"
                                context="{'group_by': 'department_id'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Tanggal" name="group_date"
                                context="{'group_by': 'overtime_date:month'}"/>
                        <filter string="Jenis Hari" name="group_type"
                                context="{'group_by': 'overtime_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================================================================
             Overtime Reject Wizard — Form View
             ================================================================ -->

        <record id="view_hr_overtime_reject_wizard_form" model="ir.ui.view">
            <field name="name">hr.overtime.reject.wizard.form</field>
            <field name="model">hr.overtime.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Alasan Penolakan">
                    <group>
                        <field name="overtime_id" readonly="1"/>
                        <field name="reject_reason" placeholder="Tuliskan alasan penolakan lembur..."/>
                    </group>
                    <footer>
                        <button name="action_confirm_reject" type="object"
                                string="Konfirmasi Tolak" class="btn-danger"/>
                        <button string="Batal" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ================================================================
             Actions
             ================================================================ -->

        <record id="action_hr_overtime" model="ir.actions.act_window">
            <field name="name">Pengajuan Lembur</field>
            <field name="res_model">hr.overtime</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="search_view_id" ref="view_hr_overtime_search"/>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Buat Pengajuan Lembur Pertama Anda!
                </p>
                <p>
                    Catat kegiatan lembur dan kirim ke atasan untuk disetujui.
                    Setelah disetujui, upah lembur akan otomatis masuk ke slip gaji bulan ini.
                </p>
            </field>
        </record>

        <!-- Action: Perlu Disetujui (untuk Manager) -->
        <record id="action_hr_overtime_to_approve" model="ir.actions.act_window">
            <field name="name">Lembur Perlu Disetujui</field>
            <field name="res_model">hr.overtime</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'submitted'), ('manager_id.user_id', '=', uid)]</field>
            <field name="context">{}</field>
        </record>

    </data>
</odoo>
