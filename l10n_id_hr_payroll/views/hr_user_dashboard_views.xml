<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             HR User Dashboard — Form View
             ================================================================ -->

        <record id="view_hr_user_dashboard_form" model="ir.ui.view">
            <field name="name">hr.user.dashboard.form</field>
            <field name="model">hr.user.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard HR" create="false" edit="false">
                    <sheet>
                        <div class="oe_title mb-4">
                            <h1>
                                <span>Dashboard HR</span>
                            </h1>
                            <p class="text-muted">Ringkasan untuk Tim Human Resources</p>
                        </div>

                        <!-- Trial Banner -->
                        <div class="alert alert-warning" role="alert"
                             invisible="not trial_expired">
                            <strong>Masa Uji Coba Berakhir / Trial Expired</strong><br/>
                            Fitur payroll terbatas (read-only). Hubungi vendor untuk lisensi.
                            <br/>Email: susilo.cdv@gmail.com |
                            LinkedIn: linkedin.com/in/susilo-raden-68a19049
                        </div>
                        <div class="alert alert-info" role="alert"
                             invisible="trial_expired or trial_days_left >= 3">
                            <strong>Sisa masa uji coba: </strong>
                            <field name="trial_days_left" readonly="1" nolabel="1"/> hari
                        </div>

                        <!-- Stats Cards -->
                        <div class="row mb-4">
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-primary h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-users fa-3x text-primary mb-2"/>
                                        <h2 class="mb-1 text-primary">
                                            <field name="employee_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Karyawan Aktif</small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-success h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-file-text-o fa-3x text-success mb-2"/>
                                        <h2 class="mb-1 text-success">
                                            <field name="payslip_computed_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Slip Gaji Siap</small>
                                        <br/>
                                        <span class="badge bg-warning text-dark">
                                            <field name="payslip_draft_count" readonly="1" nolabel="1"/> Draft
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-warning h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-clock-o fa-3x text-warning mb-2"/>
                                        <h2 class="mb-1 text-warning">
                                            <field name="overtime_pending_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">Lembur Pending</small>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card border-danger h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-gift fa-3x text-danger mb-2"/>
                                        <h2 class="mb-1 text-danger">
                                            <field name="thr_pending_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <small class="text-muted text-uppercase fw-bold">THR Draft</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Quick Actions -->
                        <div class="row mb-4">
                            <div class="col-lg-4 col-md-6 mb-3">
                                <div class="card border-secondary h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-list fa-3x text-secondary mb-2"/>
                                        <h6>Slip Gaji</h6>
                                        <p class="text-muted small mb-2">Lihat daftar slip gaji</p>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           name="action_open_my_payslips" type="object">
                                            <i class="fa fa-eye"/> Lihat Slip Gaji
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-6 mb-3">
                                <div class="card border-secondary h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-check fa-3x text-secondary mb-2"/>
                                        <h6>Review Lembur</h6>
                                        <p class="text-muted small mb-2">Approve/reject pengajuan lembur</p>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           name="action_open_overtime_pending" type="object">
                                            <i class="fa fa-check"/> Review Lembur
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4 col-md-6 mb-3">
                                <div class="card border-secondary h-100 shadow-sm">
                                    <div class="card-body text-center">
                                        <i class="fa fa-gift fa-3x text-secondary mb-2"/>
                                        <h6>Daftar THR</h6>
                                        <p class="text-muted small mb-2">Kelola tunjangan hari raya</p>
                                    </div>
                                    <div class="card-footer bg-transparent text-center py-2">
                                        <a class="btn btn-outline-secondary btn-sm"
                                           name="action_open_thr" type="object">
                                            <i class="fa fa-eye"/> Lihat THR
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================
             HR User Dashboard — Action
             ================================================================ -->

        <record id="action_hr_user_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard HR</field>
            <field name="res_model">hr.user.dashboard</field>
            <field name="view_mode">form</field>
            <field name="views" eval="[(ref('view_hr_user_dashboard_form'), 'form')]"/>
        </record>

    </data>
</odoo>
