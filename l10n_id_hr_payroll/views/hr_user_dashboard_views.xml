<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             HR User Dashboard — Form View
             ================================================================ -->

        <record id="view_hr_user_dashboard_form" model="ir.ui.view">
            <field name="name">hr.user.dashboard.form</field>
            <field name="model">hr.user.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard HR" create="false" edit="false">
                    <sheet>
                        <div class="l10n_id_dashboard">

                            <!-- Trial Banner — Expired -->
                            <div class="sapTrialBanner sapTrialBanner--danger" role="alert"
                                 invisible="not trial_expired">
                                <strong>Masa Uji Coba Berakhir / Trial Expired</strong><br/>
                                Fitur payroll terbatas (read-only). Hubungi vendor untuk lisensi.
                                <br/>Email: susilo.cdv@gmail.com |
                                LinkedIn: linkedin.com/in/susilo-raden-68a19049
                            </div>
                            <!-- Trial Banner — Warning -->
                            <div class="sapTrialBanner sapTrialBanner--warning" role="alert"
                                 invisible="trial_expired or trial_days_left >= 3">
                                <strong>Sisa masa uji coba: </strong>
                                <field name="trial_days_left" readonly="1" nolabel="1"/> hari
                            </div>

                            <!-- ════════════════════════════════════════════════════════ -->
                            <!-- KPI Row — Overview                                       -->
                            <!-- ════════════════════════════════════════════════════════ -->
                            <div class="sapKpiRow">

                                <!-- Karyawan Aktif -->
                                <div class="sapKpiTile sapKpiTile--info">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-users"/> Karyawan Aktif
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="employee_count" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">Total aktif</div>
                                </div>

                                <!-- Hadir Hari Ini -->
                                <div class="sapKpiTile sapKpiTile--positive">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-check-circle"/> Hadir Hari Ini
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="hadir_hari_ini" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__detail">
                                        <a name="action_open_attendance" type="object">
                                            <i class="fa fa-eye"/> Lihat Absensi
                                        </a>
                                    </div>
                                </div>

                                <!-- Tidak Hadir -->
                                <div class="sapKpiTile sapKpiTile--negative">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-times-circle"/> Tidak Hadir
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="tidak_hadir_hari_ini" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">Absen hari ini</div>
                                </div>

                                <!-- Cuti Pending -->
                                <div class="sapKpiTile sapKpiTile--critical">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-hourglass-o"/> Cuti Pending
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="cuti_pending" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__detail">
                                        <a name="action_open_leave_pending" type="object">
                                            <i class="fa fa-check"/> Review Cuti
                                        </a>
                                    </div>
                                </div>

                                <!-- Cuti Sakit -->
                                <div class="sapKpiTile sapKpiTile--neutral">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-medkit"/> Cuti Sakit
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="cuti_sakit" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">Sedang sakit</div>
                                </div>

                                <!-- Slip Gaji Draft -->
                                <div class="sapKpiTile sapKpiTile--info">
                                    <div class="sapKpiTile__title">
                                        <i class="fa fa-file-text-o"/> Slip Gaji Draft
                                    </div>
                                    <div class="sapKpiTile__value">
                                        <field name="payslip_draft_count" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapKpiTile__subtitle">
                                        <field name="payslip_computed_count" readonly="1" nolabel="1"/> siap
                                    </div>
                                    <div class="sapKpiTile__detail">
                                        <a name="action_open_my_payslips" type="object">
                                            <i class="fa fa-eye"/> Lihat Slip Gaji
                                        </a>
                                    </div>
                                </div>

                            </div>

                            <!-- ════════════════════════════════════════════════════════ -->
                            <!-- Quick Actions — Lainnya                                  -->
                            <!-- ════════════════════════════════════════════════════════ -->
                            <div class="sapSectionTitle">
                                <i class="fa fa-bolt"/> Lainnya
                            </div>
                            <div class="sapQuickActions">

                                <!-- Lembur Pending -->
                                <a class="sapQuickAction sapKpiTile--critical"
                                   name="action_open_overtime_pending" type="object">
                                    <div class="sapQuickAction__icon">
                                        <i class="fa fa-clock-o"/>
                                    </div>
                                    <div class="sapQuickAction__label">Lembur Pending</div>
                                    <div class="sapQuickAction__desc">
                                        <field name="overtime_pending_count" readonly="1" nolabel="1"/> perlu review
                                    </div>
                                </a>

                                <!-- THR -->
                                <a class="sapQuickAction"
                                   name="action_open_thr" type="object">
                                    <div class="sapQuickAction__icon">
                                        <i class="fa fa-gift"/>
                                    </div>
                                    <div class="sapQuickAction__label">THR</div>
                                    <div class="sapQuickAction__desc">Kelola tunjangan hari raya</div>
                                </a>

                                <!-- Expense Pending -->
                                <div class="sapQuickAction">
                                    <div class="sapQuickAction__icon">
                                        <i class="fa fa-receipt"/>
                                    </div>
                                    <div class="sapQuickAction__label">Expense Pending</div>
                                    <div class="sapQuickAction__desc">
                                        <field name="expense_pending" readonly="1" nolabel="1"/> menunggu
                                    </div>
                                </div>

                            </div>

                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ================================================================
             HR User Dashboard — Action
             ================================================================ -->

        <record id="action_hr_user_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard HR</field>
            <field name="res_model">hr.user.dashboard</field>
            <field name="view_mode">form</field>
            <field name="views" eval="[(ref('view_hr_user_dashboard_form'), 'form')]"/>
        </record>

    </data>
</odoo>
