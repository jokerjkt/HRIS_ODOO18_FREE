<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Payslip Form — SAP Fiori Object Page
             ================================================================ -->

        <record id="view_hr_payslip_form" model="ir.ui.view">
            <field name="name">hr.payslip.form</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <form string="Slip Gaji Indonesia">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,computed,done"/>
                    </header>
                    <sheet>

                        <!-- ─── Form Header ──────────────────────────────────── -->
                        <div class="sapFormHeader">
                            <div class="sapFormHeader__left">
                                <div class="sapFormHeader__avatar">
                                    <i class="fa fa-file-text-o"/>
                                </div>
                                <div>
                                    <div class="sapFormHeader__title">
                                        <field name="employee_id" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="sapFormHeader__subtitle">Slip Gaji</div>
                                </div>
                            </div>
                            <div class="sapFormHeader__actions">
                                <field name="state" widget="badge"
                                       decoration-info="state == 'draft'"
                                       decoration-success="state == 'computed'"
                                       decoration-warning="state == 'done'"
                                       decoration-muted="state == 'cancel'"
                                       class="sapFormStatus"/>
                                <button name="action_compute" string="Hitung Gaji"
                                        type="object" class="btn-primary"
                                        invisible="state != 'draft'"/>
                                <button name="action_confirm" string="Konfirmasi"
                                        type="object" class="btn-primary"
                                        invisible="state != 'computed'"/>
                                <button name="action_cancel" string="Batalkan"
                                        type="object" class="btn-secondary"
                                        invisible="state not in ('draft', 'computed', 'done')"/>
                                <button name="action_reset_draft" string="Reset ke Draft"
                                        type="object"
                                        invisible="state == 'draft'"/>
                            </div>
                        </div>

                        <!-- ─── KPI Summary Bar ──────────────────────────────── -->
                        <div class="sapFormSummary">
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--positive">
                                    <i class="fa fa-money"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">Gaji Bersih</div>
                                    <div class="sapFormSummary__value">
                                        <field name="net_wage" widget="monetary"
                                               readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--negative">
                                    <i class="fa fa-calculator"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">PPh 21</div>
                                    <div class="sapFormSummary__value">
                                        <field name="pph21_amount" widget="monetary"
                                               readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--critical">
                                    <i class="fa fa-shield"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">BPJS Potongan</div>
                                    <div class="sapFormSummary__value">
                                        <field name="bpjs_potongan_karyawan" widget="monetary"
                                               readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapFormSummary__item">
                                <div class="sapFormSummary__icon sapFormSummary__icon--neutral">
                                    <i class="fa fa-clock-o"/>
                                </div>
                                <div>
                                    <div class="sapFormSummary__label">Lembur</div>
                                    <div class="sapFormSummary__value">
                                        <field name="overtime_total" widget="monetary"
                                               readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ─── Stat Buttons ─────────────────────────────────── -->
                        <div class="sapStatButtons">
                            <div class="sapStatButton">
                                <div class="sapStatButton__icon">
                                    <i class="fa fa-id-card"/>
                                </div>
                                <div class="sapStatButton__text">
                                    <div class="sapStatButton__title">Kontrak</div>
                                    <div class="sapStatButton__value">
                                        <field name="contract_id" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapStatButton">
                                <div class="sapStatButton__icon">
                                    <i class="fa fa-building-o"/>
                                </div>
                                <div class="sapStatButton__text">
                                    <div class="sapStatButton__title">Departemen</div>
                                    <div class="sapStatButton__value">
                                        <field name="department_id" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                            <div class="sapStatButton">
                                <div class="sapStatButton__icon">
                                    <i class="fa fa-calendar"/>
                                </div>
                                <div class="sapStatButton__text">
                                    <div class="sapStatButton__title">Periode</div>
                                    <div class="sapStatButton__value">
                                        <field name="date_from" readonly="1" nolabel="1"/>
                                        s/d
                                        <field name="date_to" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ─── Form Sections ────────────────────────────────── -->

                        <!-- Section: Informasi Karyawan -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Informasi Karyawan</div>
                            <group>
                                <group>
                                    <field name="employee_id"/>
                                    <field name="contract_id"/>
                                    <field name="department_id" readonly="1"/>
                                </group>
                            </group>
                        </div>

                        <!-- Section: Periode & THR -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Periode &amp; THR</div>
                            <group>
                                <group>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="include_thr"/>
                                    <field name="thr_amount" widget="monetary"
                                           invisible="not include_thr"/>
                                </group>
                            </group>
                        </div>

                        <!-- Section: Detail Tabs -->
                        <div class="sapFormSection">
                            <div class="sapFormSection__title">Rincian Perhitungan</div>
                            <notebook>
                                <page name="tab_penghasilan" string="Penghasilan">
                                    <group string="Komponen Penghasilan">
                                        <field name="gaji_pokok" widget="monetary" readonly="1"/>
                                        <field name="tunjangan_tetap" widget="monetary" readonly="1"/>
                                        <field name="tunjangan_tidak_tetap" widget="monetary" readonly="1"/>
                                        <field name="overtime_total" widget="monetary" readonly="1"
                                               string="Upah Lembur"/>
                                        <separator string=""/>
                                        <field name="total_penghasilan" widget="monetary" readonly="1"
                                               class="oe_subtotal_footer"/>
                                    </group>
                                </page>

                                <page name="tab_pph21" string="PPh 21">
                                    <field name="pph21_ids" readonly="1">
                                        <list>
                                            <field name="penghasilan_bruto" widget="monetary" string="Bruto Bulanan"/>
                                            <field name="biaya_jabatan" widget="monetary" string="Biaya Jabatan"/>
                                            <field name="ptkp_status"/>
                                            <field name="ptkp_amount" widget="monetary" string="PTKP/tahun"/>
                                            <field name="pkp_tahunan" widget="monetary" string="PKP/tahun"/>
                                            <field name="pph21_bulanan" widget="monetary" string="PPh21/bulan"/>
                                            <field name="npwp_has" string="Ada NPWP?"/>
                                            <field name="pph21_surcharge" widget="monetary" string="Surcharge +20%"/>
                                            <field name="pph21_final" widget="monetary" string="PPh21 Final"/>
                                        </list>
                                    </field>

                                    <div class="sapStatButtons mt-3" name="pph21_actions">
                                        <button name="action_view_pph21_detail"
                                                type="object"
                                                string="Lihat Rincian PPh 21"
                                                class="sapStatButton"
                                                icon="fa-calculator"/>
                                        <button name="action_print_bukti_potong"
                                                type="object"
                                                string="Cetak Bukti Potong"
                                                class="sapStatButton"
                                                icon="fa-print"/>
                                    </div>
                                </page>

                                <page name="tab_bpjs" string="BPJS">
                                    <div class="sapFormSummary mb-3">
                                        <div class="sapFormSummary__item">
                                            <div class="sapFormSummary__icon sapFormSummary__icon--negative">
                                                <i class="fa fa-user"/>
                                            </div>
                                            <div>
                                                <div class="sapFormSummary__label">Potongan Karyawan</div>
                                                <div class="sapFormSummary__value">
                                                    <field name="bpjs_potongan_karyawan" widget="monetary"
                                                           readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="sapFormSummary__item">
                                            <div class="sapFormSummary__icon sapFormSummary__icon--positive">
                                                <i class="fa fa-building"/>
                                            </div>
                                            <div>
                                                <div class="sapFormSummary__label">Kontribusi Perusahaan</div>
                                                <div class="sapFormSummary__value">
                                                    <field name="bpjs_kontribusi_perusahaan" widget="monetary"
                                                           readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <field name="bpjs_ids" readonly="1">
                                        <list>
                                            <field name="upah_dasar" widget="monetary" string="Upah Dasar"/>
                                            <field name="jht_emp" widget="monetary" string="JHT Kary (2%)"/>
                                            <field name="jp_emp" widget="monetary" string="JP Kary (1%)"/>
                                            <field name="bpjs_kes_emp" widget="monetary" string="BPJS Kes Kary (1%)"/>
                                            <field name="total_potongan_karyawan" widget="monetary" string="Total Potong"/>
                                            <field name="jkk_comp" widget="monetary" string="JKK Perush"/>
                                            <field name="jkm_comp" widget="monetary" string="JKM (0.3%)"/>
                                            <field name="jht_comp" widget="monetary" string="JHT Perush (3.7%)"/>
                                            <field name="jp_comp" widget="monetary" string="JP Perush (2%)"/>
                                            <field name="bpjs_kes_comp" widget="monetary" string="BPJS Kes Perush (4%)"/>
                                            <field name="total_kontribusi_perusahaan" widget="monetary" string="Total Kontribusi"/>
                                        </list>
                                    </field>

                                    <div class="sapStatButtons mt-3" name="bpjs_actions">
                                        <button name="action_view_bpjs_detail"
                                                type="object"
                                                string="Lihat Rincian BPJS"
                                                class="sapStatButton"
                                                icon="fa-shield"/>
                                    </div>
                                </page>

                                <page name="tab_overtime" string="Lembur">
                                    <div class="sapFormSummary mb-3">
                                        <div class="sapFormSummary__item">
                                            <div class="sapFormSummary__icon sapFormSummary__icon--neutral">
                                                <i class="fa fa-calendar-check-o"/>
                                            </div>
                                            <div>
                                                <div class="sapFormSummary__label">Jumlah Hari Lembur</div>
                                                <div class="sapFormSummary__value">
                                                    <field name="overtime_count" readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="sapFormSummary__item">
                                            <div class="sapFormSummary__icon sapFormSummary__icon--critical">
                                                <i class="fa fa-money"/>
                                            </div>
                                            <div>
                                                <div class="sapFormSummary__label">Total Upah Lembur</div>
                                                <div class="sapFormSummary__value">
                                                    <field name="overtime_total" widget="monetary"
                                                           readonly="1" nolabel="1"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <field name="overtime_ids" readonly="1">
                                        <list>
                                            <field name="overtime_date"/>
                                            <field name="start_time" widget="float_time"/>
                                            <field name="end_time" widget="float_time"/>
                                            <field name="duration" string="Durasi (jam)"/>
                                            <field name="overtime_type"/>
                                            <field name="reason"/>
                                            <field name="activity_description"/>
                                            <field name="overtime_pay" widget="monetary"/>
                                            <field name="state" widget="badge"
                                                   decoration-success="state == 'approved'"
                                                   decoration-warning="state == 'submitted'"
                                                   decoration-danger="state == 'rejected'"/>
                                        </list>
                                    </field>
                                    <div class="text-center mt-3">
                                        <button name="action_link_overtime"
                                                type="object"
                                                string="Hubungkan Lembur ke Payslip Ini"
                                                class="btn btn-outline-info"/>
                                    </div>
                                </page>

                                <page name="tab_thr" string="THR">
                                    <group string="Tunjangan Hari Raya">
                                        <field name="include_thr"/>
                                        <field name="thr_amount" widget="monetary"
                                               invisible="not include_thr"/>
                                    </group>
                                </page>
                            </notebook>
                        </div>

                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ================================================================
             Payslip List View
             ================================================================ -->

        <record id="view_hr_payslip_list" model="ir.ui.view">
            <field name="name">hr.payslip.list</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <list string="Daftar Slip Gaji"
                      decoration-success="state == 'done'"
                      decoration-muted="state == 'cancel'">
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="department_id" optional="show"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="gaji_pokok" widget="monetary" string="Gaji Pokok" optional="show"/>
                    <field name="pph21_amount" widget="monetary" string="PPh 21"/>
                    <field name="bpjs_potongan_karyawan" widget="monetary" string="BPJS Pot." optional="show"/>
                    <field name="net_wage" widget="monetary" string="Gaji Bersih"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'done'"
                           decoration-info="state == 'computed'"
                           decoration-danger="state == 'cancel'"/>
                </list>
            </field>
        </record>

        <!-- ================================================================
             Payslip Search View
             ================================================================ -->

        <record id="view_hr_payslip_search" model="ir.ui.view">
            <field name="name">hr.payslip.search</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <search string="Cari Slip Gaji">
                    <field name="name" string="No. Transaksi"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <separator/>
                    <filter string="Draft" name="draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Dihitung" name="computed"
                            domain="[('state', '=', 'computed')]"/>
                    <filter string="Selesai" name="done"
                            domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Departemen" name="group_department"
                                context="{'group_by': 'department_id'}"/>
                        <filter string="Periode" name="group_period"
                                context="{'group_by': 'date_from:month'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ================================================================
             Payslip Action
             ================================================================ -->

        <record id="action_hr_payslip" model="ir.actions.act_window">
            <field name="name">Slip Gaji</field>
            <field name="res_model">hr.payslip</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_hr_payslip_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Belum ada slip gaji
                </p>
                <p>
                    Buat slip gaji baru untuk karyawan, lalu klik
                    <strong>"Hitung Gaji"</strong> untuk menghitung PPh 21 dan BPJS
                    secara otomatis.
                </p>
            </field>
        </record>

    </data>
</odoo>
