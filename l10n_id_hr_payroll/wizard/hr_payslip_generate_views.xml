<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Buat Slip Gaji Massal — Wizard Form
             ================================================================ -->

        <record id="view_hr_payslip_generate_wizard_form" model="ir.ui.view">
            <field name="name">hr.payslip.generate.wizard.form</field>
            <field name="model">hr.payslip.generate.wizard</field>
            <field name="arch" type="xml">
                <form string="Buat Slip Gaji Massal">
                    <group string="Periode Gaji">
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="auto_compute"/>
                        </group>
                        <group>
                            <field name="department_ids" widget="many2many_tags"
                                   placeholder="Kosongkan = semua departemen"/>
                            <field name="employee_ids" widget="many2many_tags"
                                   placeholder="Kosongkan = semua karyawan aktif"/>
                        </group>
                    </group>

                    <group string="Preview">
                        <group>
                            <field name="preview_count" readonly="1"
                                   string="Karyawan Eligible"/>
                            <field name="existing_count" readonly="1"
                                   string="Sudah Ada (dilewati)"/>
                        </group>
                        <group>
                            <field name="preview_total" widget="monetary" readonly="1"
                                   string="Estimasi Total Gaji (Rp)"/>
                        </group>
                    </group>

                    <div class="alert alert-info" role="alert"
                         invisible="existing_count == 0">
                        <strong>Catatan:</strong>
                        Beberapa karyawan sudah memiliki slip gaji untuk periode ini
                        dan akan dilewati.
                    </div>

                    <footer>
                        <button name="action_generate_payslips" type="object"
                                string="Buat Slip Gaji" class="btn-primary"/>
                        <button string="Batal" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ================================================================
             Buat Slip Gaji Massal — Action
             ================================================================ -->

        <record id="action_hr_payslip_generate_wizard" model="ir.actions.act_window">
            <field name="name">Buat Slip Gaji Massal</field>
            <field name="res_model">hr.payslip.generate.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
