<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Rekap Iuran BPJS — Report (Enhanced)
             ================================================================ -->

        <record id="action_report_bpjs_rekap" model="ir.actions.report">
            <field name="name">Rekap Iuran BPJS</field>
            <field name="model">hr.bpjs.submission</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">l10n_id_hr_payroll.report_bpjs_rekap</field>
            <field name="report_file">l10n_id_hr_payroll.report_bpjs_rekap</field>
        </record>

        <template id="report_bpjs_rekap">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="batch">
                    <t t-call="web.external_layout">
                        <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif;">

                            <!-- Header -->
                            <div class="text-center mb-4">
                                <h2 style="color: #1a237e; margin-bottom: 5px;">REKAP IURAN BPJS</h2>
                                <h4 style="color: #666; margin-bottom: 5px;">
                                    <t t-esc="batch.company_id.name"/>
                                </h4>
                                <p style="color: #666; margin: 0;">
                                    Periode: <strong><t t-esc="batch.date_start.strftime('%B %Y')"/></strong>
                                </p>
                            </div>

                            <hr style="border-top: 2px solid #1a237e;"/>

                            <!-- Tabel Rekap per Karyawan -->
                            <table class="table table-bordered table-sm" style="font-size: 9px;">
                                <thead style="background: #1a237e; color: white;">
                                    <tr>
                                        <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">No</th>
                                        <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">Nama Karyawan</th>
                                        <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">No BPJS TK</th>
                                        <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">No BPJS Kes</th>
                                        <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">Upah Dasar</th>
                                        <th colspan="3" class="text-center" style="border-color: #1a237e; background: #283593;">Karyawan</th>
                                        <th colspan="5" class="text-center" style="border-color: #1a237e; background: #283593;">Perusahaan</th>
                                        <th colspan="2" class="text-center" style="border-color: #1a237e; background: #283593;">Total</th>
                                    </tr>
                                    <tr>
                                        <th style="border-color: #1a237e; background: #3949ab;">JHT 2%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">JP 1%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">Kes 1%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">JKK</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">JKM 0.3%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">JHT 3.7%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">JP 2%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">Kes 4%</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">Kary</th>
                                        <th style="border-color: #1a237e; background: #3949ab;">Perush</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="total_upah"   t-value="0"/>
                                    <t t-set="total_jht_e"  t-value="0"/>
                                    <t t-set="total_jp_e"   t-value="0"/>
                                    <t t-set="total_kes_e"  t-value="0"/>
                                    <t t-set="total_jkk"    t-value="0"/>
                                    <t t-set="total_jkm"    t-value="0"/>
                                    <t t-set="total_jht_c"  t-value="0"/>
                                    <t t-set="total_jp_c"   t-value="0"/>
                                    <t t-set="total_kes_c"  t-value="0"/>

                                    <t t-foreach="batch.slip_ids.filtered(lambda s: s.state == 'done')" t-as="slip">
                                        <t t-set="b" t-value="slip.bpjs_ids[0] if slip.bpjs_ids else None"/>
                                        <tr t-att-style="'background: #f5f5f5;' if slip_index % 2 == 0 else ''">
                                            <td class="text-center" style="border-color: #e0e0e0;"><t t-esc="slip_index + 1"/></td>
                                            <td style="border-color: #e0e0e0;"><t t-esc="slip.employee_id.name"/></td>
                                            <td style="border-color: #e0e0e0;"><t t-esc="slip.employee_id.bpjs_tk_no or '-'"/></td>
                                            <td style="border-color: #e0e0e0;"><t t-esc="slip.employee_id.bpjs_kes_no or '-'"/></td>
                                            <t t-if="b">
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.upah_dasar)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jht_emp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jp_emp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.bpjs_kes_emp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jkk_comp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jkm_comp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jht_comp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.jp_comp)"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(b.bpjs_kes_comp)"/></td>
                                                <td class="text-right font-weight-bold" style="border-color: #e0e0e0; color: #1a237e;">
                                                    <t t-esc="'{:,.0f}'.format(b.total_potongan_karyawan)"/>
                                                </td>
                                                <td class="text-right font-weight-bold" style="border-color: #e0e0e0; color: #2e7d32;">
                                                    <t t-esc="'{:,.0f}'.format(b.total_kontribusi_perusahaan)"/>
                                                </td>
                                            </t>
                                            <t t-else="">
                                                <td colspan="10" class="text-center text-muted" style="border-color: #e0e0e0;">—</td>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot style="background: #1a237e; color: white;">
                                    <tr>
                                        <td colspan="5" style="border-color: #1a237e;">TOTAL</td>
                                        <td class="text-right" colspan="9" style="border-color: #1a237e;">
                                            (lihat ringkasan di bawah)
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>

                            <!-- Ringkasan -->
                            <div class="mt-4">
                                <strong style="color: #1a237e;">RINGKASAN IURAN BPJS PERIODE
                                    <t t-esc="batch.date_start.strftime('%B %Y').upper()"/>
                                </strong>
                                <table class="table table-bordered mt-2" style="max-width: 500px;">
                                    <tr>
                                        <td style="color: #666;"><strong>Total Potongan Karyawan</strong></td>
                                        <td class="text-right">
                                            Rp <t t-esc="'{:,.0f}'.format(sum(slip.bpjs_potongan_karyawan for slip in batch.slip_ids.filtered(lambda s: s.state == 'done')))"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;"><strong>Total Kontribusi Perusahaan</strong></td>
                                        <td class="text-right">
                                            Rp <t t-esc="'{:,.0f}'.format(sum(slip.bpjs_kontribusi_perusahaan for slip in batch.slip_ids.filtered(lambda s: s.state == 'done')))"/>
                                        </td>
                                    </tr>
                                    <tr style="background: #e8f5e9;">
                                        <td><strong style="color: #2e7d32;">GRAND TOTAL DISETOR KE BPJS</strong></td>
                                        <td class="text-right font-weight-bold" style="color: #2e7d32;">
                                            Rp <t t-esc="'{:,.0f}'.format(sum(slip.bpjs_potongan_karyawan + slip.bpjs_kontribusi_perusahaan for slip in batch.slip_ids.filtered(lambda s: s.state == 'done')))"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <div class="text-muted small mt-4">
                                <em>Dicetak: <t t-esc="context_today().strftime('%d %B %Y')"/></em>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
