<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Rekap Iuran BPJS — Report (Enhanced)
             ================================================================ -->

        <record id="action_report_bpjs_rekap" model="ir.actions.report">
            <field name="name">Rekap Iuran BPJS</field>
            <field name="model">hr.bpjs.submission</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">l10n_id_hr_payroll.report_bpjs_rekap</field>
            <field name="report_file">l10n_id_hr_payroll.report_bpjs_rekap</field>
        </record>

        <template id="report_bpjs_rekap">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="batch">
                    <t t-call="web.external_layout">
                        <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif;">

                            <!-- Header -->
                            <div class="text-center mb-4">
                                <h2 style="color: #1a237e; margin-bottom: 5px;">REKAP IURAN BPJS</h2>
                                <h4 style="color: #666; margin-bottom: 5px;">
                                    <t t-esc="batch.name"/>
                                </h4>
                                <p style="color: #666; margin: 0;">
                                    Periode: <strong><t t-esc="str(batch.period_month).zfill(2)"/>/<t t-esc="batch.period_year"/></strong>
                                    | Jenis: <strong><t t-esc="dict(batch._fields['service_type']._description_selection(batch.env)).get(batch.service_type, batch.service_type)"/></strong>
                                </p>
                            </div>

                            <hr style="border-top: 2px solid #1a237e;"/>

                            <!-- Info jika kosong -->
                            <t t-if="not batch.line_ids">
                                <div class="text-center mt-5 mb-5" style="padding: 60px 0;">
                                    <div style="font-size: 48px; color: #ccc; margin-bottom: 15px;">&#128203;</div>
                                    <h4 style="color: #999; margin-bottom: 10px;">Belum Ada Data Iuran</h4>
                                    <p style="color: #bbb; margin: 0;">
                                        Silakan generate data iuran terlebih dahulu melalui tombol<br/>
                                        <strong>"Generate Data Iuran"</strong> pada form submission ini.
                                    </p>
                                    <div class="mt-4" style="color: #ddd; font-size: 12px;">
                                        Periode: <t t-esc="str(batch.period_month).zfill(2)"/>/<t t-esc="batch.period_year"/>
                                        | <t t-esc="dict(batch._fields['service_type']._description_selection(batch.env)).get(batch.service_type, batch.service_type)"/>
                                    </div>
                                </div>
                            </t>

                            <!-- Tabel jika ada data -->
                            <t t-if="batch.line_ids">
                                <table class="table table-bordered table-sm" style="font-size: 9px;">
                                    <thead style="background: #1a237e; color: white;">
                                        <tr>
                                            <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">No</th>
                                            <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">Nama Karyawan</th>
                                            <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">No BPJS</th>
                                            <th rowspan="2" style="border-color: #1a237e; vertical-align: middle;">Upah Dasar</th>
                                            <t t-if="batch.service_type == 'tk'">
                                                <th colspan="5" class="text-center" style="border-color: #1a237e; background: #283593;">Perusahaan</th>
                                                <th colspan="3" class="text-center" style="border-color: #1a237e; background: #283593;">Karyawan</th>
                                            </t>
                                            <t t-else="">
                                                <th class="text-center" style="border-color: #1a237e; background: #283593;">Kes Karyawan 1%</th>
                                                <th class="text-center" style="border-color: #1a237e; background: #283593;">Kes Perusahaan 4%</th>
                                            </t>
                                            <th class="text-center" style="border-color: #1a237e; background: #283593;">Total</th>
                                        </tr>
                                        <tr>
                                            <t t-if="batch.service_type == 'tk'">
                                                <th style="border-color: #1a237e; background: #3949ab;">JKK</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">JKM</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">JHT 3.7%</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">JP 2%</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">Kes 4%</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">JHT 2%</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">JP 1%</th>
                                                <th style="border-color: #1a237e; background: #3949ab;">Kes 1%</th>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="grand_total" t-value="0"/>
                                        <t t-foreach="batch.line_ids" t-as="line">
                                            <tr t-att-style="'background: #f5f5f5;' if line_index % 2 == 0 else ''">
                                                <td class="text-center" style="border-color: #e0e0e0;"><t t-esc="line_index + 1"/></td>
                                                <td style="border-color: #e0e0e0;"><t t-esc="line.employee_id.name"/></td>
                                                <td style="border-color: #e0e0e0;"><t t-esc="line.bpjs_no or '-'"/></td>
                                                <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.wage_base)"/></td>
                                                <t t-if="batch.service_type == 'tk'">
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jkk)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jkm)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jht_comp)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jp_comp)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(0)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jht_emp)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.jp_emp)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(0)"/></td>
                                                </t>
                                                <t t-else="">
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.bpjs_kes_emp)"/></td>
                                                    <td class="text-right" style="border-color: #e0e0e0;"><t t-esc="'{:,.0f}'.format(line.bpjs_kes_comp)"/></td>
                                                </t>
                                                <td class="text-right font-weight-bold" style="border-color: #e0e0e0; color: #1a237e;">
                                                    <t t-esc="'{:,.0f}'.format(line.total_iuran)"/>
                                                </td>
                                                <t t-set="grand_total" t-value="grand_total + line.total_iuran"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot style="background: #1a237e; color: white;">
                                        <tr>
                                            <td colspan="4" style="border-color: #1a237e;">TOTAL</td>
                                            <td class="text-right font-weight-bold" style="border-color: #1a237e;">
                                                Rp <t t-esc="'{:,.0f}'.format(grand_total)"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>

                                <!-- Ringkasan -->
                                <div class="mt-4">
                                    <strong style="color: #1a237e;">RINGKASAN IURAN BPJS</strong>
                                    <table class="table table-bordered mt-2" style="max-width: 500px;">
                                        <tr>
                                            <td style="color: #666;"><strong>Jumlah Karyawan</strong></td>
                                            <td class="text-right"><t t-esc="batch.total_employee"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>Total Iuran</strong></td>
                                            <td class="text-right font-weight-bold" style="color: #1a237e;">
                                                Rp <t t-esc="'{:,.0f}'.format(batch.total_amount)"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </t>

                            <div class="text-muted small mt-4">
                                <em>Dicetak: <t t-esc="context_today().strftime('%d %B %Y')"/></em>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
