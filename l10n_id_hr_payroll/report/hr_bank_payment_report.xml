<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Report: Daftar Pembayaran Gaji via Bank Transfer
             ================================================================ -->

        <record id="action_report_bank_payment" model="ir.actions.report">
            <field name="name">Daftar Pembayaran Gaji via Bank</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">l10n_id_hr_payroll.report_bank_payment_list</field>
            <field name="report_file">l10n_id_hr_payroll.report_bank_payment_list</field>
            <field name="binding_model_id" ref="model_hr_payslip"/>
            <field name="binding_type">report</field>
        </record>

        <!-- ================================================================
             QWeb Template
             ================================================================ -->

        <template id="report_bank_payment_list">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="record" t-if="record._is_first()">
                    <t t-call="web.external_layout">
                        <div class="page"
                             style="font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px;">

                            <!-- Header -->
                            <div class="text-center mb-4">
                                <h2 style="color: #1a237e; margin-bottom: 5px;">
                                    DAFTAR PEMBAYARAN GAJI VIA BANK TRANSFER
                                </h2>
                                <h4 style="color: #555; font-weight: normal;">
                                    Periode: <t t-esc="record.date_from"/>
                                    s/d <t t-esc="record.date_to"/>
                                </h4>
                                <p class="text-muted" style="font-size: 10px;">
                                   Dicetak: <t t-esc="record.create_date" t-options="{'widget': 'date'}"/>
                                </p>
                            </div>

                            <!-- Summary -->
                            <div class="row mb-3">
                                <div class="col-4">
                                    <div class="card border-primary">
                                        <div class="card-body text-center py-2">
                                            <small class="text-muted">TOTAL KARYAWAN</small>
                                            <h4 class="mb-0 text-primary" t-esc="len(docs)"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card border-success">
                                        <div class="card-body text-center py-2">
                                            <small class="text-muted">TOTAL GAJI BERSIH</small>
                                            <h4 class="mb-0 text-success">
                                                Rp <t t-esc="'{:,.0f}'.format(sum(docs.mapped('net_wage')))"/>
                                            </h4>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="card border-secondary">
                                        <div class="card-body text-center py-2">
                                            <small class="text-muted">PERIODE</small>
                                            <h4 class="mb-0 text-secondary" style="font-size: 14px;">
                                                <t t-esc="record.date_from"/>
                                                s/d
                                                <t t-esc="record.date_to"/>
                                            </h4>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Table -->
                            <table class="table table-bordered table-sm" style="font-size: 10px;">
                                <thead>
                                    <tr style="background-color: #1a237e; color: white;">
                                        <th class="text-center" style="width: 40px;">No</th>
                                        <th>No. Transaksi</th>
                                        <th>Nama Karyawan</th>
                                        <th>Departemen</th>
                                        <th>Nama Bank</th>
                                        <th>No. Rekening</th>
                                        <th>Atas Nama</th>
                                        <th class="text-end" style="width: 130px;">Gaji Bersih (Rp)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="docs" t-as="slip">
                                        <tr>
                                            <td class="text-center" t-esc="slip._origin.id"/>
                                            <td>
                                                <strong t-esc="slip.name"/>
                                            </td>
                                            <td>
                                                <strong t-esc="slip.employee_id.name"/>
                                            </td>
                                            <td t-esc="slip.department_id.name or '-'"/>
                                            <td t-esc="slip.bank_name or '-'"/>
                                            <td>
                                                <span t-if="slip.bank_account_number"
                                                      t-esc="slip.bank_account_number"/>
                                                <span t-else="" class="text-danger">BELUM DIISI</span>
                                            </td>
                                            <td t-esc="slip.bank_account_name or '-'"/>
                                            <td class="text-end">
                                                <strong style="color: #2e7d32;">
                                                    Rp <t t-esc="'{:,.0f}'.format(slip.net_wage)"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #e8f5e9; font-weight: bold;">
                                        <td colspan="7" class="text-end">
                                            <strong>TOTAL PEMBAYARAN</strong>
                                        </td>
                                        <td class="text-end" style="color: #1b5e20;">
                                            <strong>
                                                Rp <t t-esc="'{:,.0f}'.format(sum(docs.mapped('net_wage')))"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>

                            <!-- Footer Notes -->
                            <div class="mt-4" style="font-size: 10px;">
                                <p class="text-muted">
                                    <i class="fa fa-info-circle"/> Catatan:
                                </p>
                                <ul class="text-muted">
                                    <li>Data bank diambil dari data master karyawan.</li>
                                    <li>Pastikan nomor rekening dan nama bank sudah benar sebelum transfer.</li>
                                    <li>Gaji bersih sudah termasuk PPh 21 dan potongan BPJS.</li>
                                </ul>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
