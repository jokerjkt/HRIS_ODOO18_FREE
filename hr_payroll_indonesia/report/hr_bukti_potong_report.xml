<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Bukti Potong PPh 21 — Formulir 1721-A1/A2 (Enhanced)
             ================================================================ -->

        <record id="action_report_bukti_potong" model="ir.actions.report">
            <field name="name">Bukti Potong PPh 21 (1721-A1/A2)</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hr_payroll_indonesia.report_bukti_potong</field>
            <field name="report_file">hr_payroll_indonesia.report_bukti_potong</field>
        </record>

        <template id="report_bukti_potong">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="slip">
                    <t t-call="web.external_layout">
                        <div class="page" style="font-size: 11px; font-family: 'Segoe UI', Arial, sans-serif;">

                            <!-- Header Formulir -->
                            <div class="text-center mb-3">
                                <h3 style="color: #1a237e; margin-bottom: 5px;">
                                    BUKTI PEMOTONGAN PPh PASAL 21
                                </h3>
                                <p class="mb-0">
                                    <t t-if="slip.employee_id.employee_contract_type == 'permanent'">
                                        <strong style="color: #2e7d32;">FORMULIR 1721-A1</strong>
                                        <span class="badge badge-success ml-2">Pegawai Tetap</span>
                                    </t>
                                    <t t-else="">
                                        <strong style="color: #e65100;">FORMULIR 1721-A2</strong>
                                        <span class="badge badge-warning ml-2">Pegawai Tidak Tetap / Tenaga Ahli</span>
                                    </t>
                                </p>
                                <p style="color: #666; margin: 0;">
                                    Tahun Pajak: <strong><t t-esc="slip.date_from.year"/></strong>
                                </p>
                            </div>

                            <hr style="border-top: 2px solid #1a237e;"/>

                            <!-- A. Identitas Pemotong Pajak -->
                            <div class="mb-3 p-3 rounded" style="background: #e8eaf6;">
                                <strong style="color: #1a237e;">A. IDENTITAS PEMOTONG PAJAK</strong>
                                <table class="table table-sm table-borderless mt-1" style="margin-bottom: 0;">
                                    <tr>
                                        <td style="width: 40%; color: #666;">NPWP Perusahaan</td>
                                        <td>: <t t-esc="slip.company_id.vat or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">Nama Perusahaan</td>
                                        <td>: <t t-esc="slip.company_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">Alamat</td>
                                        <td>:
                                            <t t-esc="slip.company_id.street or ''"/>
                                            <t t-if="slip.company_id.city">, <t t-esc="slip.company_id.city"/></t>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- B. Identitas Penerima Penghasilan -->
                            <div class="mb-3 p-3 rounded" style="background: #fff3e0;">
                                <strong style="color: #e65100;">B. IDENTITAS PENERIMA PENGHASILAN YANG DIPOTONG</strong>
                                <table class="table table-sm table-borderless mt-1" style="margin-bottom: 0;">
                                    <tr>
                                        <td style="width: 40%; color: #666;">NPWP</td>
                                        <td>: <t t-esc="slip.employee_id.npwp or 'TIDAK MEMILIKI NPWP'"/>
                                            <t t-if="not slip.employee_id.npwp_has">
                                                <span class="badge badge-danger ml-2">Tarif +20%</span>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">Nama</td>
                                        <td>: <t t-esc="slip.employee_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">NIK</td>
                                        <td>: <t t-esc="slip.employee_id.nik or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">Status PTKP</td>
                                        <td>: <t t-esc="slip.employee_id.ptkp_status"/></td>
                                    </tr>
                                    <tr>
                                        <td style="color: #666;">Jumlah Tanggungan</td>
                                        <td>: <t t-esc="slip.employee_id.ptkp_status.split('/')[-1] if slip.employee_id.ptkp_status else '0'"/> orang</td>
                                    </tr>
                                </table>
                            </div>

                            <!-- C. Rincian Penghasilan dan Penghitungan PPh 21 -->
                            <div class="mb-3">
                                <strong style="color: #1a237e;">C. RINCIAN PENGHASILAN DAN PENGHITUNGAN PPh PASAL 21</strong>
                                <t t-if="slip.pph21_ids">
                                    <t t-set="pph" t-value="slip.pph21_ids[0]"/>
                                    <table class="table table-bordered table-sm mt-1" style="font-size: 10px;">
                                        <tbody>
                                            <tr>
                                                <td style="color: #666;">1. Gaji Pokok / Pensiun</td>
                                                <td class="text-right">Rp <t t-esc="'{:,.0f}'.format(pph.gaji_pokok)"/></td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">2. Tunjangan Tetap</td>
                                                <td class="text-right">Rp <t t-esc="'{:,.0f}'.format(pph.tunjangan_tetap)"/></td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">3. Tunjangan Tidak Tetap / Bonus / THR</td>
                                                <td class="text-right">Rp <t t-esc="'{:,.0f}'.format(pph.tunjangan_lain + pph.bonus_thr)"/></td>
                                            </tr>
                                            <tr style="background: #e8eaf6;">
                                                <td><strong>4. Penghasilan Bruto Sebulan</strong></td>
                                                <td class="text-right"><strong>Rp <t t-esc="'{:,.0f}'.format(pph.penghasilan_bruto)"/></strong></td>
                                            </tr>
                                            <tr style="background: #e8eaf6;">
                                                <td><strong>5. Penghasilan Bruto Setahun (x12)</strong></td>
                                                <td class="text-right"><strong>Rp <t t-esc="'{:,.0f}'.format(pph.penghasilan_bruto_tahunan)"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">6. Biaya Jabatan (5%, maks Rp 6.000.000/tahun)</td>
                                                <td class="text-right">(Rp <t t-esc="'{:,.0f}'.format(pph.biaya_jabatan * 12)"/>)</td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">7. Iuran JHT Karyawan (2%)</td>
                                                <td class="text-right">(Rp <t t-esc="'{:,.0f}'.format(pph.bpjs_tk_jht_emp * 12)"/>)</td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">8. Iuran JP Karyawan (1%)</td>
                                                <td class="text-right">(Rp <t t-esc="'{:,.0f}'.format(pph.bpjs_tk_jp_emp * 12)"/>)</td>
                                            </tr>
                                            <tr style="background: #e3f2fd;">
                                                <td><strong>9. Penghasilan Neto Setahun</strong></td>
                                                <td class="text-right"><strong>Rp <t t-esc="'{:,.0f}'.format(pph.penghasilan_neto)"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">10. PTKP (<t t-esc="pph.ptkp_status"/>)</td>
                                                <td class="text-right">(Rp <t t-esc="'{:,.0f}'.format(pph.ptkp_amount)"/>)</td>
                                            </tr>
                                            <tr style="background: #fff3e0;">
                                                <td><strong>11. Penghasilan Kena Pajak (PKP) Setahun</strong></td>
                                                <td class="text-right"><strong>Rp <t t-esc="'{:,.0f}'.format(pph.pkp_tahunan)"/></strong></td>
                                            </tr>
                                            <tr>
                                                <td style="color: #666;">12. PPh 21 Terutang Setahun (tarif progresif)</td>
                                                <td class="text-right">Rp <t t-esc="'{:,.0f}'.format(pph.pph21_tahunan)"/></td>
                                            </tr>
                                            <t t-if="not pph.npwp_has">
                                                <tr style="background: #ffebee;">
                                                    <td style="color: #c62828;">13. Surcharge Tanpa NPWP (+20%)</td>
                                                    <td class="text-right text-danger">Rp <t t-esc="'{:,.0f}'.format(pph.pph21_surcharge * 12)"/></td>
                                                </tr>
                                            </t>
                                            <tr style="background: #e8f5e9; font-size: 1.1em;">
                                                <td><strong style="color: #2e7d32;">PPh 21 DIPOTONG BULAN INI</strong></td>
                                                <td class="text-right"><strong style="color: #2e7d32;">Rp <t t-esc="'{:,.0f}'.format(pph.pph21_final)"/></strong></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <p class="text-muted">Data PPh 21 belum tersedia untuk slip gaji ini.</p>
                                </t>
                            </div>

                            <!-- Tarif Referensi -->
                            <div class="mb-3 p-2 border rounded" style="background: #f5f5f5; border-color: #e0e0e0 !important; font-size: 10px;">
                                <strong style="color: #666;">Tarif Progresif PPh 21 (Pasal 17 UU HPP):</strong><br/>
                                <span style="color: #666;">
                                    0 - Rp 60 jt: 5% | Rp 60 - 250 jt: 15% | Rp 250 - 500 jt: 25% |
                                    Rp 500 jt - 5 M: 30% | &gt; Rp 5 M: 35%
                                </span>
                            </div>

                            <!-- Tanda Tangan -->
                            <div class="row mt-4">
                                <div class="col-6 text-center">
                                    <p style="color: #666;">Penerima Bukti Potong,</p>
                                    <br/><br/><br/>
                                    <p style="border-top: 1px solid #ccc; padding-top: 5px; display: inline-block; width: 200px;">
                                        ( <t t-esc="slip.employee_id.name"/> )
                                    </p>
                                    <p class="small" style="color: #666;">NPWP: <t t-esc="slip.employee_id.npwp or '-'"/></p>
                                </div>
                                <div class="col-6 text-center">
                                    <p style="color: #666;">
                                        <t t-esc="slip.company_id.city or '________________'"/>,
                                        <t t-esc="slip.date_to.strftime('%d %B %Y')"/>
                                    </p>
                                    <p style="color: #666;">Pemotong Pajak,</p>
                                    <br/><br/><br/>
                                    <p style="border-top: 1px solid #ccc; padding-top: 5px; display: inline-block; width: 200px;">
                                        ( _________________________ )
                                    </p>
                                    <p class="small" style="color: #666;"><t t-esc="slip.company_id.name"/></p>
                                </div>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
