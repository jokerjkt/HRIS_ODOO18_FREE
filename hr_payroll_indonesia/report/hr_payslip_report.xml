<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ================================================================
             Slip Gaji Indonesia — Report Template (Enhanced)
             ================================================================ -->

        <record id="action_report_payslip_indonesia" model="ir.actions.report">
            <field name="name">Slip Gaji Indonesia</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hr_payroll_indonesia.report_payslip_indonesia</field>
            <field name="report_file">hr_payroll_indonesia.report_payslip_indonesia</field>
        </record>

        <template id="report_payslip_indonesia">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="slip">
                    <t t-call="web.external_layout">
                        <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif;">

                            <!-- Header -->
                            <div class="row mb-4">
                                <div class="col-6">
                                    <h2 style="color: #1a237e; margin-bottom: 5px;">SLIP GAJI</h2>
                                    <p style="color: #666; margin: 0;">
                                        Periode: <strong><t t-esc="slip.date_from.strftime('%B %Y')"/></strong>
                                    </p>
                                </div>
                                <div class="col-6 text-right">
                                    <h4 style="color: #1a237e;"><t t-esc="slip.company_id.name"/></h4>
                                    <p class="small" style="color: #666; margin: 0;">
                                        <t t-esc="slip.company_id.street or ''"/><br/>
                                        <t t-esc="slip.company_id.city or ''"/>
                                        <t t-if="slip.company_id.country_id">, <t t-esc="slip.company_id.country_id.name"/></t>
                                    </p>
                                </div>
                            </div>

                            <hr style="border-top: 2px solid #1a237e;"/>

                            <!-- Informasi Karyawan -->
                            <div class="row mb-3">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                                        <tr>
                                            <td style="width: 40%; color: #666;"><strong>Nama</strong></td>
                                            <td>: <t t-esc="slip.employee_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>NIK</strong></td>
                                            <td>: <t t-esc="slip.employee_id.nik or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>NPWP</strong></td>
                                            <td>: <t t-esc="slip.employee_id.npwp or 'Tidak Ada (tarif +20%)'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>Jabatan</strong></td>
                                            <td>: <t t-esc="slip.employee_id.job_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>Departemen</strong></td>
                                            <td>: <t t-esc="slip.employee_id.department_id.name or '-'"/></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="table table-sm table-borderless" style="margin-bottom: 0;">
                                        <tr>
                                            <td style="width: 40%; color: #666;"><strong>Status PTKP</strong></td>
                                            <td>: <t t-esc="slip.employee_id.ptkp_status or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>No BPJS TK</strong></td>
                                            <td>: <t t-esc="slip.employee_id.bpjs_tk_no or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>No BPJS Kes</strong></td>
                                            <td>: <t t-esc="slip.employee_id.bpjs_kes_no or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;"><strong>Periode</strong></td>
                                            <td>:
                                                <t t-esc="slip.date_from.strftime('%d/%m/%Y')"/>
                                                s/d
                                                <t t-esc="slip.date_to.strftime('%d/%m/%Y')"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Tabel Komponen Gaji -->
                            <table class="table table-bordered table-sm" style="font-size: 11px;">
                                <thead style="background: #1a237e; color: white;">
                                    <tr>
                                        <th style="border-color: #1a237e;">Uraian</th>
                                        <th class="text-right" style="border-color: #1a237e;">Jumlah (Rp)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Penghasilan -->
                                    <tr style="background: #e8eaf6;">
                                        <td colspan="2" style="border-color: #c5cae9;">
                                            <strong style="color: #1a237e;">A. PENGHASILAN</strong>
                                        </td>
                                    </tr>
                                    <t t-foreach="slip.line_ids.filtered(lambda l: l.category_id.code == 'BRUTO' and l.total != 0)" t-as="line">
                                        <tr>
                                            <td style="padding-left: 20px; border-color: #e0e0e0;">
                                                <t t-esc="line.name"/>
                                            </td>
                                            <td class="text-right" style="border-color: #e0e0e0;">
                                                <t t-esc="'{:,.0f}'.format(line.total)"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr style="background: #e3f2fd; font-weight: bold;">
                                        <td style="border-color: #bbdefb;">Total Penghasilan Bruto</td>
                                        <td class="text-right" style="border-color: #bbdefb;">
                                            <t t-esc="'{:,.0f}'.format(sum(slip.line_ids.filtered(lambda l: l.category_id.code == 'BRUTO').mapped('total')))"/>
                                        </td>
                                    </tr>

                                    <!-- Potongan Karyawan -->
                                    <tr style="background: #fff3e0;">
                                        <td colspan="2" style="border-color: #ffe0b2;">
                                            <strong style="color: #e65100;">B. POTONGAN KARYAWAN</strong>
                                        </td>
                                    </tr>
                                    <t t-foreach="slip.line_ids.filtered(lambda l: l.category_id.code == 'POTONG' and l.total != 0)" t-as="line">
                                        <tr>
                                            <td style="padding-left: 20px; border-color: #e0e0e0;">
                                                <t t-esc="line.name"/>
                                            </td>
                                            <td class="text-right text-danger" style="border-color: #e0e0e0;">
                                                (<t t-esc="'{:,.0f}'.format(abs(line.total))"/>)
                                            </td>
                                        </tr>
                                    </t>
                                    <tr style="background: #fbe9e7; font-weight: bold;">
                                        <td style="border-color: #ffccbc;">Total Potongan</td>
                                        <td class="text-right text-danger" style="border-color: #ffccbc;">
                                            (<t t-esc="'{:,.0f}'.format(abs(sum(slip.line_ids.filtered(lambda l: l.category_id.code == 'POTONG').mapped('total'))))"/>)
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr style="background: #e8f5e9; font-size: 1.1em;">
                                        <th style="border-color: #c8e6c9; color: #2e7d32;">
                                            GAJI BERSIH DITERIMA
                                        </th>
                                        <th class="text-right" style="border-color: #c8e6c9; color: #2e7d32;">
                                            Rp <t t-esc="'{:,.0f}'.format(slip.net_wage)"/>
                                        </th>
                                    </tr>
                                </tfoot>
                            </table>

                            <!-- Kontribusi Perusahaan (informatif) -->
                            <div class="mt-3">
                                <p class="small" style="color: #666;">
                                    <strong>Catatan — Kontribusi Perusahaan (tidak mengurangi gaji bersih):</strong>
                                </p>
                                <table class="table table-sm" style="font-size: 0.85em;">
                                    <t t-foreach="slip.line_ids.filtered(lambda l: l.category_id.code == 'COMP' and l.total != 0)" t-as="line">
                                        <tr>
                                            <td><t t-esc="line.name"/></td>
                                            <td class="text-right">Rp <t t-esc="'{:,.0f}'.format(line.total)"/></td>
                                        </tr>
                                    </t>
                                </table>
                            </div>

                            <!-- PPh 21 Info -->
                            <t t-if="slip.pph21_ids">
                                <div class="mt-3 p-3 border rounded" style="background: #f3e5f5; border-color: #ce93d8 !important;">
                                    <strong style="color: #6a1b9a;">Rincian PPh 21 Bulan Ini:</strong>
                                    <table class="table table-sm table-borderless" style="font-size: 0.85em; margin-bottom: 0;">
                                        <tr>
                                            <td style="color: #666;">PKP Tahunan</td>
                                            <td>: Rp <t t-esc="'{:,.0f}'.format(slip.pph21_pkp)"/></td>
                                            <td style="color: #666;">Status PTKP</td>
                                            <td>: <t t-esc="slip.employee_id.ptkp_status"/></td>
                                        </tr>
                                        <tr>
                                            <td style="color: #666;">PPh 21 Setahun</td>
                                            <td>: Rp <t t-esc="'{:,.0f}'.format(slip.pph21_tahunan)"/></td>
                                            <td style="color: #666;">PPh 21 Bulan Ini</td>
                                            <td>: Rp <t t-esc="'{:,.0f}'.format(slip.pph21_amount)"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </t>

                            <!-- Footer / Tanda Tangan -->
                            <div class="row mt-5">
                                <div class="col-6 text-center">
                                    <p style="color: #666;">Karyawan,</p>
                                    <br/><br/><br/>
                                    <p style="border-top: 1px solid #ccc; padding-top: 5px; display: inline-block; width: 200px;">
                                        ( <t t-esc="slip.employee_id.name"/> )
                                    </p>
                                </div>
                                <div class="col-6 text-center">
                                    <p style="color: #666;">HRD / Penggajian,</p>
                                    <br/><br/><br/>
                                    <p style="border-top: 1px solid #ccc; padding-top: 5px; display: inline-block; width: 200px;">
                                        ( _________________________ )
                                    </p>
                                </div>
                            </div>

                            <div class="text-center mt-4 text-muted small">
                                <em>Slip gaji ini dicetak secara otomatis oleh sistem dan sah tanpa tanda tangan basah.</em>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
